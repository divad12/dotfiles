#!/usr/bin/env python3
"""
Audit ask-intern adoption from local telemetry and agent/session logs.

The goal is not perfect attribution. It surfaces likely misses: sessions with
several direct file reads and no ask-intern invocation.
"""

import argparse
import csv
import json
import os
import re
import shlex
import sys
import time
from collections import Counter, defaultdict
from pathlib import Path


DEFAULT_EVENTS = Path("~/.config/ask-intern/events.tsv").expanduser()
DEFAULT_ATTEMPTS = Path("~/.config/ask-intern/attempts.jsonl").expanduser()
DEFAULT_GUARD_EVENTS = Path("~/.config/ask-intern/read-guard/events.jsonl").expanduser()
DEFAULT_LOG_ROOTS = [
    Path("~/.codex/sessions").expanduser(),
    Path("~/.codex/archived_sessions").expanduser(),
    Path("~/.claude/projects").expanduser(),
]

DIRECT_READ_RE = re.compile(
    r"(^|[;&|]\s*|\b)(cat|head|tail)\s+|"
    r"\bsed\s+-n\b|"
    r"\bnl\s+-ba\b",
)
ASK_INTERN_RE = re.compile(r"(^|[\s/])ask-intern(\s|$)")
EXACT_PROMPT_RE = re.compile(
    r"\b(verbatim|exact lines?|line numbers?|quote exact|exact code|complete source|full source|exact contents|print exact)\b",
    re.IGNORECASE,
)
NEGATED_EXACT_PROMPT_RE = re.compile(
    r"\b(?:do\s+not|don['’]?t|dont|without|no|not|never)\b"
    r"(?:(?![.;!?\n]).){0,120}"
    r"\b("
    r"verbatim|exact|source|code|text|contents?|lines?|line[- ]numbered|"
    r"line\s+numbers?|complete\s+source|full\s+source|print|quote|show|"
    r"reproduce|include|provide|ask(?:ing)?\s+for"
    r")\b",
    re.IGNORECASE,
)
POST_NEGATED_EXACT_PROMPT_RE = re.compile(
    r"\b("
    r"verbatim|exact|source|code|text|contents?|lines?|line[- ]numbered|"
    r"line\s+numbers?|complete\s+source|full\s+source|print|quote|show|"
    r"reproduce|include|provide"
    r")\b"
    r"(?:(?![.;!?\n]).){0,80}"
    r"\b(?:not\s+needed|not\s+required|not\s+necessary|unneeded|unnecessary|not\s+wanted)\b",
    re.IGNORECASE,
)
CONTROL_BASENAMES = {"AGENTS.md", "CLAUDE.md", "PROGRESS.md", "SKILL.md"}
SENSITIVE_BASENAMES = {".env", ".env.local"}
GENERATED_SEGMENTS = {"graphify-out", "node_modules"}
CONTROL_SEGMENTS = {".git"}
BINARY_EXTENSIONS = {
    ".avif",
    ".bin",
    ".gif",
    ".ico",
    ".jpeg",
    ".jpg",
    ".mov",
    ".mp4",
    ".pdf",
    ".png",
    ".tar",
    ".webp",
    ".zip",
}
CHUNK_BYPASS_LINES = 800


def command_values(record):
    """Yield actual tool-call commands, not arbitrary strings from transcripts."""
    cwd = record.get("cwd", "")
    message = record.get("message")
    if isinstance(message, dict):
        content = message.get("content")
        if isinstance(content, list):
            for item in content:
                if not isinstance(item, dict) or item.get("type") != "tool_use":
                    continue
                tool_input = item.get("input") or {}
                if not isinstance(tool_input, dict):
                    continue
                if item.get("name") == "Bash":
                    command = tool_input.get("command")
                    if isinstance(command, str):
                        yield command, cwd
                elif item.get("name") == "Read":
                    path = tool_input.get("file_path") or tool_input.get("path")
                    if isinstance(path, str):
                        yield f"Read {path}", cwd

    payload = record.get("payload")
    if isinstance(payload, dict) and payload.get("type") == "function_call":
        name = payload.get("name", "")
        if name in {"exec_command", "functions.exec_command"}:
            try:
                arguments = json.loads(payload.get("arguments") or "{}")
            except json.JSONDecodeError:
                arguments = {}
            command = arguments.get("cmd") if isinstance(arguments, dict) else None
            cwd = arguments.get("workdir") if isinstance(arguments, dict) else cwd
            if isinstance(command, str):
                yield command, cwd


def event_epoch(timestamp):
    try:
        return time.mktime(time.strptime(timestamp, "%Y-%m-%d %H:%M:%S"))
    except (TypeError, ValueError):
        return 0


def load_events(path, since_days=None):
    summary = {
        "total": 0,
        "success": 0,
        "failure": 0,
        "failures": Counter(),
        "sources": Counter(),
        "rows": [],
    }
    if not path.exists():
        return summary
    cutoff = time.time() - since_days * 24 * 60 * 60 if since_days is not None else None

    with path.open(newline="") as f:
        reader = csv.DictReader(f, delimiter="\t")
        for row in reader:
            if cutoff is not None and event_epoch(row.get("timestamp")) < cutoff:
                continue
            summary["rows"].append(row)
            status = row.get("status", "")
            reason = row.get("reason", "")
            source = row.get("source") or "unknown"
            summary["total"] += 1
            summary["sources"][source] += 1
            if status == "success":
                summary["success"] += 1
            elif status == "failure":
                summary["failure"] += 1
                summary["failures"][reason or "unknown"] += 1
    return summary


def resolve_file(path, cwd):
    expanded = Path(os.path.expanduser(path))
    if not expanded.is_absolute():
        expanded = Path(cwd or os.getcwd()) / expanded
    return expanded


def line_count(path, cwd, cache):
    try:
        resolved = resolve_file(path, cwd).resolve()
        if resolved not in cache:
            with resolved.open("rb") as f:
                cache[resolved] = sum(1 for _ in f)
        return cache[resolved]
    except OSError:
        return None


def row_files(row):
    return [path for path in (row.get("files") or "").split(",") if path]


def clause_prefix(text, index):
    start = 0
    for marker in (".", ";", "!", "?", "\n"):
        marker_index = text.rfind(marker, 0, index)
        if marker_index >= start:
            start = marker_index + 1
    return text[start:index]


def clause_suffix(text, index):
    end = len(text)
    markers = [position for marker in (".", ";", "!", "?", "\n") if (position := text.find(marker, index)) != -1]
    if markers:
        end = min(markers)
    return text[index:end]


def is_negated_exact_prompt_match(text, match):
    return bool(
        NEGATED_EXACT_PROMPT_RE.search(clause_prefix(text, match.end()))
        or POST_NEGATED_EXACT_PROMPT_RE.search(clause_suffix(text, match.start()))
    )


def is_exact_prompt(text):
    normalized = (text or "").replace("'\"'\"'", "'")
    for match in EXACT_PROMPT_RE.finditer(normalized):
        if is_negated_exact_prompt_match(normalized, match):
            continue
        return True
    return False


def summarize_over_delegations(rows, limit):
    line_cache = {}
    exact_prompts = []
    single_small = []
    docs_only = []

    for row in rows:
        invocation = row.get("invocation") or ""
        files = row_files(row)
        counts = [line_count(path, row.get("cwd", ""), line_cache) for path in files]
        if is_exact_prompt(invocation):
            exact_prompts.append((row, counts))
        if len(files) == 1 and counts and counts[0] is not None and counts[0] <= 400 and not row.get("target"):
            single_small.append((row, counts))
        if files and all(is_exempt_direct_read_path(path) for path in files):
            docs_only.append((row, counts))

    print("possible over-delegations:")
    print(f"- exact/verbatim prompts: {len(exact_prompts)}")
    print(f"- single-file calls under 400 lines: {len(single_small)}")
    print(f"- docs/control/generated-only calls: {len(docs_only)}")
    examples = exact_prompts[-limit:]
    if examples:
        print("recent exact/verbatim examples:")
        for row, counts in examples:
            invocation = short_command(row.get("invocation") or "", 160)
            print(
                f"- {row.get('timestamp')} {row.get('source') or 'unknown'} "
                f"{row.get('status')} {row.get('reason')}: lines={counts} {invocation}"
            )


def load_jsonl_events(path, since_days=None):
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except FileNotFoundError:
        return []

    cutoff = None
    if since_days is not None:
        cutoff = time.time() - since_days * 24 * 60 * 60

    events = []
    for line in lines:
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if cutoff is not None and event.get("ts", 0) < cutoff:
            continue
        events.append(event)
    return events


def row_latency(row):
    try:
        return float(row.get("latency_s") or 0)
    except (TypeError, ValueError):
        return 0.0


def summarize_slow_calls(rows, attempts, slow_seconds, limit):
    slow_rows = [row for row in rows if row_latency(row) >= slow_seconds]
    slow_rows.sort(key=row_latency)

    started = {}
    ended = set()
    for attempt in attempts:
        attempt_id = attempt.get("attempt_id")
        if not attempt_id:
            continue
        if attempt.get("event") == "start":
            started[attempt_id] = attempt
        elif attempt.get("event") == "end":
            ended.add(attempt_id)

    abandoned = [
        attempt
        for attempt_id, attempt in started.items()
        if attempt_id not in ended and (time.time() - safe_int(attempt.get("ts"))) >= slow_seconds
    ]
    abandoned.sort(key=lambda attempt: safe_int(attempt.get("ts")))

    print(f"slow/hang-shaped calls: {len(slow_rows)} over {slow_seconds:g}s")
    if slow_rows:
        print("recent slow calls:")
        for row in slow_rows[-limit:]:
            latency = row_latency(row)
            invocation = short_command(row.get("invocation") or "", 160)
            print(
                f"- {row.get('timestamp')} {row.get('source') or 'unknown'} "
                f"{row.get('status')} {row.get('reason')} {latency:.1f}s "
                f"files={row.get('file_count') or 0}: {invocation}"
            )

    print(f"attempt log events: {len(attempts)}")
    print(f"abandoned attempts: {len(abandoned)}")
    for attempt in abandoned[-limit:]:
        invocation = short_command(attempt.get("invocation") or "", 160)
        paths = path_names(attempt.get("files") or [])
        age = max(0, time.time() - safe_int(attempt.get("ts")))
        print(
            f"- {timestamp_label(safe_int(attempt.get('ts')))} "
            f"{attempt.get('source') or 'unknown'} age={age:.0f}s files={paths}: {invocation}"
        )


def timestamp_label(ts):
    if not ts:
        return "unknown-time"
    return time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(ts))


def short_command(command, limit=120):
    command = (command or "").replace("\n", " ")
    if len(command) <= limit:
        return command
    return command[: limit - 3] + "..."


def path_names(paths, limit=3):
    names = [Path(path).name for path in paths[:limit]]
    if len(paths) > limit:
        names.append(f"+{len(paths) - limit} more")
    return ", ".join(names) if names else "(no paths)"


def describe_guard_event(event):
    parts = [
        timestamp_label(event.get("ts")),
        event.get("source") or "unknown-source",
        event.get("reason") or "unknown",
        event.get("tool") or "unknown-tool",
        path_names(event.get("paths") or []),
    ]
    metrics = []
    if event.get("read_lines") is not None:
        metrics.append(f"read_lines={event.get('read_lines')}")
    if event.get("total_lines") is not None:
        metrics.append(f"total_lines={event.get('total_lines')}")
    if event.get("distinct_files") is not None:
        metrics.append(f"files={event.get('distinct_files')}")
    if metrics:
        parts.append(" ".join(metrics))

    tool_input = event.get("tool_input") if isinstance(event.get("tool_input"), dict) else {}
    command = event.get("command") or tool_input.get("command", "")
    if command:
        parts.append(f"cmd={short_command(command)}")
    elif tool_input:
        parts.append(f"input={tool_input}")
    return " | ".join(parts)


def discover_logs(paths, roots, since_days=None):
    discovered = [Path(p).expanduser() for p in paths]
    for root in roots:
        root = Path(root).expanduser()
        if not root.exists():
            continue
        discovered.extend(root.rglob("*.jsonl"))
    logs = sorted({p for p in discovered if p.exists() and p.is_file()})
    if since_days is None:
        return logs

    cutoff = time.time() - (since_days * 24 * 60 * 60)
    return [p for p in logs if p.stat().st_mtime >= cutoff]


def direct_read_paths(command):
    if command.startswith("Read "):
        return [command[5:].strip()]

    paths = []
    for segment in command_segments(command):
        tokens = shell_tokens(segment)
        index = 0
        while index < len(tokens):
            command_name = os.path.basename(tokens[index])
            if command_name == "cat":
                paths.extend(command_file_args(tokens[index + 1 :], skip_first_non_option=False))
            elif command_name in {"head", "tail"}:
                paths.extend(command_file_args(tokens[index + 1 :], skip_first_non_option=False))
            elif command_name == "sed" and "-n" in tokens[index + 1 : index + 4]:
                paths.extend(command_file_args(tokens[index + 1 :], skip_first_non_option=False))
            elif command_name == "nl" and "-ba" in tokens[index + 1 : index + 4]:
                paths.extend(command_file_args(tokens[index + 1 :], skip_first_non_option=False))
            index += 1
    return paths


def is_narrow_direct_read_command(command, max_lines=200):
    if command.startswith("Read "):
        return False
    if re.search(r"(^|[;&|]\s*)cat\s+", command):
        return False

    sed_ranges = re.findall(r"\bsed\s+-n\s+['\"]?(\d+),(\d+)p['\"]?", command)
    if sed_ranges:
        return all(max(0, int(end) - int(start) + 1) <= max_lines for start, end in sed_ranges)

    head_tail_limits = re.findall(r"\b(?:head|tail)\b(?:\s+-n\s+|\s+-)(\d+)", command)
    if head_tail_limits:
        return all(int(limit) <= max_lines for limit in head_tail_limits)

    if re.search(r"\b(head|tail)\s+", command):
        return True
    return False


def command_segments(command):
    try:
        lexer = shlex.shlex(command, posix=True, punctuation_chars="|&;")
        lexer.whitespace_split = True
        tokens = list(lexer)
    except (TypeError, ValueError):
        return [segment.strip() for segment in re.split(r"\s*(?:&&|\|\||;)\s*", command) if segment.strip()]

    segments = []
    current = []
    for token in tokens:
        if token in {"&&", "||", ";", "|"}:
            if current:
                segments.append(" ".join(shlex.quote(part) for part in current))
                current = []
            continue
        current.append(token)
    if current:
        segments.append(" ".join(shlex.quote(part) for part in current))
    return segments


def shell_tokens(command):
    try:
        return shlex.split(command)
    except ValueError:
        return command.split()


def is_shell_operator(token):
    return token in {"|", "||", "&&", ";"} or token.startswith((">", "2>", "<<"))


def looks_like_path_token(token):
    if not token or token.startswith("$") or token.startswith("#"):
        return False
    if token in {"echo", "git", "grep", "sed", "nl", "ls", "wc", "readlink"}:
        return False
    basename = os.path.basename(token.rstrip(","))
    if re.fullmatch(r"\d+(?:\.\d+)+", basename):
        return False
    return "/" in token or "." in basename or basename in {"Dockerfile", "Gemfile", "Makefile", "Rakefile"}


def command_file_args(args, skip_first_non_option):
    paths = []
    skipped_payload = not skip_first_non_option
    index = 0
    while index < len(args):
        token = args[index]
        if is_shell_operator(token):
            break
        if token in {"-n", "-c", "-m"} and index + 1 < len(args):
            index += 2
            continue
        if token.startswith("-"):
            index += 1
            continue
        if not skipped_payload:
            skipped_payload = True
            index += 1
            continue
        if token not in {"-", ""} and looks_like_path_token(token):
            paths.append(token)
        index += 1
    return paths


def is_exempt_direct_read_path(path):
    if not path or path == "(unknown)":
        return True
    if path.startswith("http://") or path.startswith("https://"):
        return True
    basename = os.path.basename(path)
    suffix = Path(basename).suffix.lower()
    if basename in CONTROL_BASENAMES or basename in SENSITIVE_BASENAMES:
        return True
    if suffix in BINARY_EXTENSIONS:
        return True
    parts = set(Path(path).parts)
    if "docs" in parts or parts & GENERATED_SEGMENTS or parts & CONTROL_SEGMENTS:
        return True
    if ".agents" in parts and ("observations" in parts or "skills" in parts):
        return True
    if ".codex" in parts and ("automations" in parts or "skills" in parts):
        return True
    if ".claude" in parts and ("skills" in parts or basename in {"launch.json", "settings.json", "settings.local.json"}):
        return True
    if path.startswith("/private/tmp/") or path.startswith("/tmp/"):
        return True
    return False


def scan_log(path):
    result = {
        "ask_intern": 0,
        "direct_reads": [],
    }
    try:
        lines = path.read_text(errors="ignore").splitlines()
    except OSError:
        return result

    delegated_seen = False
    for line in lines:
        try:
            record = json.loads(line)
        except json.JSONDecodeError:
            continue
        for command, _cwd in command_values(record):
            if ASK_INTERN_RE.search(command):
                result["ask_intern"] += 1
                delegated_seen = True
            if DIRECT_READ_RE.search(command) and not ASK_INTERN_RE.search(command):
                if delegated_seen and is_narrow_direct_read_command(command):
                    continue
                for path in direct_read_paths(command):
                    if not is_exempt_direct_read_path(path):
                        result["direct_reads"].append((command, path))
    return result


def safe_int(value):
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0


def possible_chunk_read_bypasses(guard_events):
    chunks = defaultdict(lambda: {"count": 0, "total": 0, "source": "unknown", "last_ts": 0})
    for event in guard_events:
        if event.get("action") != "tracked":
            continue
        paths = event.get("paths") or []
        if len(paths) != 1:
            continue
        path = paths[0]
        if is_exempt_direct_read_path(path):
            continue
        read_lines = safe_int(event.get("read_lines"))
        if read_lines <= 0:
            continue
        key = (event.get("session") or "", path)
        chunks[key]["count"] += 1
        chunks[key]["total"] += read_lines
        chunks[key]["source"] = event.get("source") or chunks[key]["source"]
        chunks[key]["last_ts"] = max(chunks[key]["last_ts"], safe_int(event.get("ts")))

    findings = []
    for (_session, path), data in chunks.items():
        if data["count"] >= 2 and data["total"] >= CHUNK_BYPASS_LINES:
            findings.append((data["last_ts"], path, data["count"], data["total"], data["source"]))
    findings.sort()
    return findings


def main():
    parser = argparse.ArgumentParser(description="Audit ask-intern usage and likely missed delegations.")
    parser.add_argument("--events", default=str(DEFAULT_EVENTS), help="Path to ask-intern events.tsv")
    parser.add_argument("--attempts", default=str(DEFAULT_ATTEMPTS), help="Path to ask-intern attempts.jsonl")
    parser.add_argument("--guard-events", default=str(DEFAULT_GUARD_EVENTS), help="Path to read-guard events.jsonl")
    parser.add_argument("--log", action="append", default=[], help="Session JSONL log to scan (repeatable)")
    parser.add_argument("--log-root", action="append", default=[], help="Directory of JSONL logs to scan recursively")
    parser.add_argument("--since-days", type=float, default=None, help="Only scan session logs modified in the last N days")
    parser.add_argument("--min-direct-reads", type=int, default=3, help="Direct-read count that flags a session")
    parser.add_argument("--top", type=int, default=10, help="Number of top paths/sessions to print")
    parser.add_argument("--guard-limit", type=int, default=8, help="Number of recent read-guard blocks to print")
    parser.add_argument("--slow-call-seconds", type=float, default=180, help="Latency threshold for hang-shaped calls")
    args = parser.parse_args()

    events = load_events(Path(args.events).expanduser(), since_days=args.since_days)
    attempts = load_jsonl_events(Path(args.attempts).expanduser(), since_days=args.since_days)
    guard_events = load_jsonl_events(Path(args.guard_events).expanduser(), since_days=args.since_days)
    guard_blocked = [event for event in guard_events if event.get("action") == "blocked"]
    chunk_bypasses = possible_chunk_read_bypasses(guard_events)
    if args.log_root:
        log_roots = [Path(p).expanduser() for p in args.log_root]
    elif args.log:
        log_roots = []
    else:
        log_roots = DEFAULT_LOG_ROOTS
    logs = discover_logs(args.log, log_roots, since_days=args.since_days)

    total_direct_reads = 0
    top_paths = Counter()
    missed_sessions = []

    for log_path in logs:
        scan = scan_log(log_path)
        direct_reads = scan["direct_reads"]
        total_direct_reads += len(direct_reads)
        for _command, path in direct_reads:
            top_paths[path] += 1
        if len(direct_reads) >= args.min_direct_reads and scan["ask_intern"] == 0:
            missed_sessions.append((log_path, len(direct_reads), [path for _cmd, path in direct_reads[:5]]))

    print("ask-intern audit")
    print(f"events file: {Path(args.events).expanduser()}")
    print(f"ask-intern calls: {events['total']} (success {events['success']}, failure {events['failure']})")
    if events["sources"]:
        print("sources:")
        for source, count in events["sources"].most_common():
            print(f"- {source}: {count}")
    if events["failures"]:
        print("failure reasons:")
        for reason, count in events["failures"].most_common():
            print(f"- {reason}: {count}")
    summarize_slow_calls(events["rows"], attempts, args.slow_call_seconds, args.top)
    summarize_over_delegations(events["rows"], args.top)
    print(f"read-guard events: {len(guard_events)} (blocked {len(guard_blocked)})")
    if guard_blocked:
        print("read-guard blocked reasons:")
        for reason, count in Counter(event.get("reason") or "unknown" for event in guard_blocked).most_common():
            print(f"- {reason}: {count}")
        print("recent read-guard blocks:")
        for event in guard_blocked[-args.guard_limit :]:
            print(f"- {describe_guard_event(event)}")
    print(f"possible chunk-read bypasses: {len(chunk_bypasses)}")
    for _ts, path, count, total, source in chunk_bypasses[-args.guard_limit :]:
        print(f"- {source} {path}: {count} chunks, {total} total lines")
    if args.since_days is not None:
        print(f"session log window: last {args.since_days:g} days")
    print(f"session logs scanned: {len(logs)}")
    print(f"suspicious direct reads: {total_direct_reads}")
    if top_paths:
        print("top direct-read paths:")
        for path, count in top_paths.most_common(args.top):
            print(f"- {path}: {count}")
    print(f"likely missed delegations: {len(missed_sessions)}")
    for path, count, sample_paths in missed_sessions[: args.top]:
        print(f"- {path}: {count} direct reads, no ask-intern")
        if sample_paths:
            print(f"  sample paths: {', '.join(sample_paths)}")


if __name__ == "__main__":
    main()
