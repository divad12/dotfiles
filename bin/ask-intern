#!/usr/bin/env python3
"""
Cheap AI coworker for bulk reading, summarization, and boilerplate.
Called by Claude Code / Codex / any AI agent to offload token-heavy grunt work.

Usage:
    ask-intern "summarize this codebase's auth flow"
    ask-intern -f src/main.py -f src/utils.py "what do these modules do?"
    ask-intern -t tests/test_user.py -f src/user.py "write pytest tests"
    ask-intern --stats                # show usage dashboard
    ask-intern -v "debug this"        # verbose: show full request/response

Env vars:
    OPENROUTER_API_KEY      - required
    INTERN_MODEL            - default: deepseek/deepseek-v4-flash
    INTERN_MAX_TOKENS       - default: 8192 (read mode)
    INTERN_MAX_TOKENS_WRITE - default: 16384 (write-to-file mode)
"""

import sys
import os
import json
import argparse
import time
import re
import shlex
from collections import Counter
from urllib.request import Request, urlopen
from urllib.error import HTTPError

API_URL = "https://openrouter.ai/api/v1/chat/completions"
CONFIG_FILE = os.path.expanduser(os.environ.get("INTERN_ENV_FILE", "~/.config/ask-intern/env"))
ENV_NAME = re.compile(r"[A-Za-z_][A-Za-z0-9_]*")


def load_env_file(path):
    """Load simple KEY=value exports without executing shell code."""
    try:
        with open(path) as f:
            lines = f.readlines()
    except FileNotFoundError:
        return
    except OSError:
        return

    for line in lines:
        try:
            parts = shlex.split(line, comments=True, posix=True)
        except ValueError:
            continue
        if not parts:
            continue
        if parts[0] == "export":
            parts = parts[1:]
        for part in parts:
            if "=" not in part:
                continue
            key, value = part.split("=", 1)
            if ENV_NAME.fullmatch(key) and key not in os.environ:
                os.environ[key] = value


load_env_file(CONFIG_FILE)
DEFAULT_MODEL = os.environ.get("INTERN_MODEL", "deepseek/deepseek-v4-flash")
MAX_TOKENS_READ = int(os.environ.get("INTERN_MAX_TOKENS", "8192"))
MAX_TOKENS_WRITE = int(os.environ.get("INTERN_MAX_TOKENS_WRITE", "16384"))
# Weekly Opus-equivalent budget for "% saved" display.
# Max $200/month (20x) ≈ $200/week in API-equivalent usage.
WEEKLY_BUDGET = float(os.environ.get("INTERN_WEEKLY_BUDGET", "200"))
STATS_FILE = os.path.expanduser("~/.config/ask-intern/stats.tsv")
EVENTS_FILE = os.path.expanduser("~/.config/ask-intern/events.tsv")
EXACT_SOURCE_RE = re.compile(
    r"\b("
    r"verbatim|"
    r"exact\s+(?:source|code|contents?|lines?|text)|"
    r"line[- ]numbered|line\s+numbers?|"
    r"complete\s+source|full\s+source|"
    r"full\s+implementation|"
    r"all\s+imports|"
    r"show\s+(?:me\s+)?all\s+\d+\s+lines?|"
    r"print\s+(?:the\s+)?(?:file|source|code)|"
    r"quote\s+(?:the\s+)?(?:exact|key|\d+[-–]\d+)"
    r")\b",
    re.IGNORECASE,
)
NEGATED_EXACT_SOURCE_RE = re.compile(
    r"\b(?:do\s+not|don['’]?t|dont|without|no|not|never)\b"
    r"(?:(?![.;!?\n]).){0,120}"
    r"\b("
    r"verbatim|exact|source|code|text|contents?|lines?|line[- ]numbered|"
    r"line\s+numbers?|complete\s+source|full\s+source|full\s+implementation|"
    r"imports|print|quote|show|reproduce|include|provide|ask(?:ing)?\s+for"
    r")\b",
    re.IGNORECASE,
)
EVENT_FIELDS = [
    "timestamp",
    "source",
    "status",
    "reason",
    "model",
    "file_count",
    "target",
    "latency_s",
    "cwd",
    "files",
    "invocation",
]

# Pricing per million tokens (input, output)
MODEL_PRICING = {
    "deepseek/deepseek-v4-flash": (0.14, 0.28),
    "deepseek/deepseek-v4-pro": (0.435, 0.87),
    "deepseek/deepseek-chat-v3.1": (0.15, 0.75),
    "deepseek/deepseek-chat-v3-0324": (0.20, 0.77),
    "google/gemini-2.5-flash": (0.15, 0.60),
}
OPUS_PRICING = (15.0, 75.0)


def clean_field(value):
    return str(value or "").replace("\t", " ").replace("\n", " ")


def is_optional_missing_file(path):
    normalized = os.path.realpath(os.path.expanduser(path))
    temp_roots = [os.path.realpath("/tmp"), os.path.realpath("/private/tmp")]
    if any(normalized == root or normalized.startswith(root + os.sep) for root in temp_roots):
        return True
    return normalized.endswith((".log", ".out"))


def is_test_event(row):
    fields = [
        row.get("reason", ""),
        row.get("cwd", ""),
        row.get("files", ""),
        row.get("invocation", ""),
    ]
    text = " ".join(fields)
    return "intern-smoke" in text


def has_optional_missing_file(row):
    if row.get("reason", "") != "missing_file":
        return False
    files = [part.strip() for part in row.get("files", "").split(",") if part.strip()]
    return any(is_optional_missing_file(path) for path in files)


def clause_prefix(text, index):
    start = 0
    for marker in (".", ";", "!", "?", "\n"):
        marker_index = text.rfind(marker, 0, index)
        if marker_index >= start:
            start = marker_index + 1
    return text[start:index]


def is_negated_exact_source_match(text, match):
    return bool(NEGATED_EXACT_SOURCE_RE.search(clause_prefix(text, match.end())))


def is_exact_source_request(prompt):
    text = prompt or ""
    for match in EXACT_SOURCE_RE.finditer(text):
        if is_negated_exact_source_match(text, match):
            continue
        return True
    return False


def infer_source_from_text(*values):
    text = " ".join(str(value or "") for value in values).lower()
    if ".codex" in text or "/codex/" in text or "codex.app" in text:
        return "codex"
    if ".claude" in text or "/claude/" in text or "claude" in text:
        return "claude"
    return "unknown"


def detect_source():
    explicit = os.environ.get("ASK_INTERN_SOURCE", "").strip().lower()
    if explicit:
        return explicit

    env_text = "\n".join(f"{key}={value}" for key, value in os.environ.items())
    source = infer_source_from_text(env_text, os.getcwd())
    if source != "unknown":
        return source
    if "CODEX_" in env_text:
        return "codex"
    if "ANTHROPIC" in env_text:
        return "claude"

    pid = os.getppid()
    seen = set()
    while pid > 1 and pid not in seen:
        seen.add(pid)
        try:
            import subprocess

            proc = subprocess.run(
                ["ps", "-o", "comm=", "-o", "ppid=", "-p", str(pid)],
                check=False,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
            )
        except OSError:
            break
        line = proc.stdout.strip()
        if not line:
            break
        parts = line.rsplit(None, 1)
        command = parts[0].lower()
        if "codex" in command:
            return "codex"
        if "claude" in command:
            return "claude"
        try:
            pid = int(parts[1]) if len(parts) > 1 else 0
        except ValueError:
            break

    return "unknown"


def backfill_event_sources(lines, fields):
    source_index = fields.index("source")
    cwd_index = fields.index("cwd") if "cwd" in fields else None
    changed = False
    migrated = [lines[0]]

    for line in lines[1:]:
        if not line:
            migrated.append(line)
            continue
        parts = line.split("\t")
        if source_index >= len(parts) or parts[source_index] not in ("", "unknown"):
            migrated.append(line)
            continue
        source = infer_source_from_text(parts[cwd_index] if cwd_index is not None and cwd_index < len(parts) else "")
        if source == "unknown":
            migrated.append(line)
            continue
        parts[source_index] = source
        migrated.append("\t".join(parts))
        changed = True

    return migrated, changed


def ensure_events_header():
    events_dir = os.path.dirname(EVENTS_FILE)
    if events_dir:
        os.makedirs(events_dir, exist_ok=True)

    header = "\t".join(EVENT_FIELDS)
    if not os.path.exists(EVENTS_FILE) or os.path.getsize(EVENTS_FILE) == 0:
        with open(EVENTS_FILE, "w") as f:
            f.write(header + "\n")
        return

    try:
        with open(EVENTS_FILE) as f:
            lines = f.read().splitlines()
    except OSError:
        return

    if not lines:
        with open(EVENTS_FILE, "w") as f:
            f.write(header + "\n")
        return

    existing_fields = lines[0].split("\t")
    if existing_fields == EVENT_FIELDS:
        migrated, changed = backfill_event_sources(lines, existing_fields)
        if changed:
            tmp_path = f"{EVENTS_FILE}.tmp"
            with open(tmp_path, "w") as f:
                f.write("\n".join(migrated) + "\n")
            os.replace(tmp_path, EVENTS_FILE)
        return
    if "source" in existing_fields:
        return

    timestamp_index = existing_fields.index("timestamp") if "timestamp" in existing_fields else 0
    field_indexes = {name: index for index, name in enumerate(existing_fields)}
    migrated = [header]
    for line in lines[1:]:
        if not line:
            migrated.append(line)
            continue
        parts = line.split("\t")
        source = infer_source_from_text(
            parts[field_indexes["cwd"]] if "cwd" in field_indexes and field_indexes["cwd"] < len(parts) else ""
        )
        parts.insert(timestamp_index + 1, source)
        migrated.append("\t".join(parts))

    tmp_path = f"{EVENTS_FILE}.tmp"
    with open(tmp_path, "w") as f:
        f.write("\n".join(migrated) + "\n")
    os.replace(tmp_path, EVENTS_FILE)


def log_event(status, reason, model="", files=None, target=None, elapsed=0.0, invocation=None):
    from datetime import datetime, timezone

    files = files or []
    source = detect_source()
    row = "\t".join([
        datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%S"),
        clean_field(source),
        clean_field(status),
        clean_field(reason),
        clean_field(model),
        str(len(files)),
        clean_field(target),
        f"{elapsed:.2f}",
        clean_field(os.getcwd()),
        clean_field(",".join(files)),
        clean_field(invocation or " ".join(shlex.quote(arg) for arg in sys.argv)),
    ])

    try:
        ensure_events_header()
        with open(EVENTS_FILE, "a") as f:
            f.write(row + "\n")
    except OSError:
        pass


def fatal(msg, reason=None, model="", files=None, target=None, elapsed=0.0):
    if reason:
        log_event("failure", reason, model=model, files=files, target=target, elapsed=elapsed)
    print(f"ask-intern: {msg}", file=sys.stderr)
    sys.exit(1)


def deny_exact_source_request(model, files=None, target=None):
    fatal(
        "Exact/verbatim source requests should use direct small reads or narrow snippets, not ask-intern. "
        "Use `rg -n <symbol> <file>` to find anchors, then `sed -n 'START,ENDp' <file>` or a narrow Read range "
        "for the exact text. Use ask-intern for summaries, contracts, risky callers, and approximate ranges.",
        reason="exact_source_request",
        model=model,
        files=files,
        target=target,
    )


def print_stats():
    if not os.path.exists(STATS_FILE):
        print("No usage data yet.")
        return

    from datetime import datetime, timezone, timedelta

    now = datetime.now(timezone.utc)
    today = now.strftime("%Y-%m-%d")
    week_ago = (now - timedelta(days=7)).strftime("%Y-%m-%d")

    total_calls = 0
    total_in = 0
    total_out = 0
    total_cost = 0.0
    total_opus = 0.0
    total_secs = 0.0

    week_calls = 0
    week_cost = 0.0
    week_opus = 0.0

    today_calls = 0
    today_cost = 0.0
    today_opus = 0.0
    recent_failures = Counter()
    source_counts = Counter()

    with open(STATS_FILE) as f:
        next(f)  # skip header
        for line in f:
            parts = line.strip().split("\t")
            if len(parts) < 6:
                continue
            total_calls += 1
            total_in += int(parts[2])
            total_out += int(parts[3])
            total_cost += float(parts[4])
            total_opus += float(parts[5])
            if len(parts) >= 7:
                total_secs += float(parts[6])

            ts_date = parts[0][:10]
            if ts_date >= week_ago:
                week_calls += 1
                week_cost += float(parts[4])
                week_opus += float(parts[5])
            if ts_date == today:
                today_calls += 1
                today_cost += float(parts[4])
                today_opus += float(parts[5])

    if os.path.exists(EVENTS_FILE):
        ensure_events_header()
        with open(EVENTS_FILE) as f:
            header = next(f, "").rstrip("\n").split("\t")
            field_indexes = {name: index for index, name in enumerate(header)}

            def get_field(parts, name, default=""):
                index = field_indexes.get(name)
                if index is None or index >= len(parts):
                    return default
                return parts[index]

            for line in f:
                parts = line.rstrip("\n").split("\t")
                if not parts:
                    continue
                row = {
                    name: parts[index] if index < len(parts) else ""
                    for name, index in field_indexes.items()
                }
                if is_test_event(row):
                    continue
                source_counts[get_field(parts, "source", "unknown") or "unknown"] += 1
                ts_date = get_field(parts, "timestamp")[:10]
                status = get_field(parts, "status")
                reason = get_field(parts, "reason")
                if has_optional_missing_file(row):
                    continue
                if status == "failure" and ts_date >= week_ago:
                    recent_failures[reason] += 1

    saved = total_opus - total_cost
    pct = f"{saved/total_opus*100:.0f}%" if total_opus > 0 else "n/a"

    def fmt_cost(v):
        if v < 0.01:
            return f"${v:.6f}"
        return f"${v:.4f}"

    print(f"{'─' * 45}")
    print(f"  ask-intern usage stats")
    print(f"{'─' * 45}")
    week_saved = week_opus - week_cost
    budget_line = ""
    if WEEKLY_BUDGET > 0 and week_opus > 0:
        budget_pct = week_opus / WEEKLY_BUDGET * 100
        budget_line = f" = {budget_pct:.1f}% of ~${WEEKLY_BUDGET:.0f} weekly limit"
    print(f"  All time:   {total_calls} calls | {fmt_cost(total_cost)} spent | {fmt_cost(saved)} saved ({pct})")
    print(f"  This week:  {week_calls} calls | {fmt_cost(week_cost)} spent | {fmt_cost(week_saved)} saved{budget_line}")
    print(f"  Today:      {today_calls} calls | {fmt_cost(today_cost)} spent | {fmt_cost(today_opus - today_cost)} saved")
    print(f"{'─' * 45}")
    print(f"  Tokens:     {total_in:,} in / {total_out:,} out")
    if total_calls > 0 and total_secs > 0:
        print(f"  Avg latency:{total_secs/total_calls:.1f}s")
    print(f"  Opus equiv: {fmt_cost(total_opus)}")
    if source_counts:
        sources = ", ".join(f"{source} {count}" for source, count in source_counts.most_common())
        print(f"  Sources:     {sources}")
    if recent_failures:
        print(f"{'─' * 45}")
        print(f"  Recent failures: {sum(recent_failures.values())}")
        for reason, count in recent_failures.most_common():
            print(f"  - {reason}: {count}")
    print(f"{'─' * 45}")


def log_usage(model, in_tok, out_tok, elapsed, actual_cost=None):
    from datetime import datetime, timezone

    if actual_cost is not None:
        cost = actual_cost
    else:
        pricing = MODEL_PRICING.get(model, (0.50, 1.00))
        cost = (in_tok * pricing[0] + out_tok * pricing[1]) / 1_000_000
    opus_cost = (in_tok * OPUS_PRICING[0] + out_tok * OPUS_PRICING[1]) / 1_000_000

    row = "\t".join([
        datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%S"),
        model,
        str(in_tok),
        str(out_tok),
        f"{cost:.6f}",
        f"{opus_cost:.6f}",
        f"{elapsed:.2f}",
    ])

    try:
        is_new = not os.path.exists(STATS_FILE)
        stats_dir = os.path.dirname(STATS_FILE)
        if stats_dir:
            os.makedirs(stats_dir, exist_ok=True)
        with open(STATS_FILE, "a") as f:
            if is_new:
                f.write("timestamp\tmodel\tin_tokens\tout_tokens\tcost_usd\topus_equivalent_usd\tlatency_s\n")
            f.write(row + "\n")
    except OSError:
        pass


def main():
    parser = argparse.ArgumentParser(
        description="Ask a cheap model to do grunt work.",
        usage="ask-intern [-f FILE ...] [-t TARGET] [-v] [PROMPT]",
    )
    parser.add_argument("prompt", nargs="*", help="The prompt/question")
    parser.add_argument("-f", "--file", action="append", default=[], help="Files to include as context")
    parser.add_argument("-t", "--target", default=None, help="Write output directly to this file path")
    parser.add_argument("-m", "--model", default=DEFAULT_MODEL, help="Model ID override")
    parser.add_argument("-s", "--system", default=None, help="System prompt override")
    parser.add_argument("-v", "--verbose", action="store_true", help="Print full request/response to stderr")
    parser.add_argument("--stats", action="store_true", help="Print usage stats and exit")
    parser.add_argument(
        "--allow-exact-source",
        action="store_true",
        help="Bypass the exact-source misuse guard for rare manual debugging cases",
    )
    args = parser.parse_args()

    if args.stats:
        print_stats()
        return

    prompt = " ".join(args.prompt) if args.prompt else ""
    if (
        prompt
        and not args.target
        and not args.allow_exact_source
        and not os.environ.get("ASK_INTERN_ALLOW_EXACT_SOURCE")
        and is_exact_source_request(prompt)
    ):
        deny_exact_source_request(args.model, files=args.file, target=args.target)

    load_env_file(CONFIG_FILE)
    api_key = os.environ.get("OPENROUTER_API_KEY")
    if not api_key:
        fatal(
            "OPENROUTER_API_KEY not set. Get one at https://openrouter.ai/keys",
            reason="missing_api_key",
            model=args.model,
            files=args.file,
            target=args.target,
        )

    # Build context from files
    context_parts = []
    for fpath in args.file:
        try:
            with open(fpath) as f:
                content = f.read()
            context_parts.append(f"<file path=\"{fpath}\">\n{content}\n</file>")
        except FileNotFoundError as e:
            if is_optional_missing_file(fpath):
                print(f"ask-intern: Skipping missing optional file {fpath}: {e}", file=sys.stderr)
                context_parts.append(f"<missing optional file path=\"{fpath}\">File was missing when ask-intern ran.</missing optional file>")
                continue
            fatal(f"Cannot read {fpath}: {e}", reason="missing_file", model=args.model, files=args.file, target=args.target)
        except (IOError, OSError) as e:
            fatal(f"Cannot read {fpath}: {e}", reason="file_read_error", model=args.model, files=args.file, target=args.target)

    # Read stdin if piped
    if not sys.stdin.isatty():
        stdin_content = sys.stdin.read()
        if stdin_content.strip():
            context_parts.append(f"<stdin>\n{stdin_content}\n</stdin>")

    if not prompt and not context_parts:
        fatal("Nothing to do. Provide a prompt, files (-f), or pipe input.", reason="no_input", model=args.model, files=args.file, target=args.target)

    if not prompt:
        prompt = "Analyze and summarize the provided content."

    # Mode-specific system prompts and token limits
    if args.target:
        default_system = (
            "You are a code generator. Output ONLY the file content — no markdown fences, "
            "no explanation, no preamble. The output will be written directly to a file."
        )
        max_tokens = MAX_TOKENS_WRITE
    else:
        default_system = (
            "You are a precise code analyst. Answer directly without preamble. "
            "Focus on what code does, key design decisions, and non-obvious relationships. "
            "Be specific — cite function names and data flows."
        )
        max_tokens = MAX_TOKENS_READ

    system_msg = args.system or default_system

    # Split corpus and question into separate messages for prefix caching.
    # OpenRouter/DeepSeek cache the prefix of the message array — putting the
    # stable file content first means repeated queries on the same files hit cache.
    messages = [{"role": "system", "content": system_msg}]
    if context_parts:
        messages.append({"role": "user", "content": "\n\n".join(context_parts)})
        messages.append({"role": "user", "content": prompt})
    else:
        messages.append({"role": "user", "content": prompt})

    payload = {
        "model": args.model,
        "max_tokens": max_tokens,
        "messages": messages,
    }

    if args.verbose:
        print(f"[verbose] POST {API_URL}", file=sys.stderr)
        print(f"[verbose] model={args.model} max_tokens={max_tokens}", file=sys.stderr)
        print(f"[verbose] messages ({len(messages)}):", file=sys.stderr)
        for i, m in enumerate(messages):
            content_preview = m["content"][:200] + ("..." if len(m["content"]) > 200 else "")
            print(f"[verbose]   [{i}] {m['role']}: {content_preview}", file=sys.stderr)

    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
        "HTTP-Referer": "https://github.com/davidhu/dotfiles",
        "X-OpenRouter-Title": "ask-intern",
    }

    req = Request(API_URL, data=json.dumps(payload).encode(), headers=headers)

    t0 = time.time()
    try:
        with urlopen(req, timeout=120) as resp:
            data = json.loads(resp.read().decode())
    except HTTPError as e:
        elapsed = time.time() - t0
        body = e.read().decode() if e.fp else ""
        fatal(f"API error {e.code}: {body[:500]}", reason="api_error", model=args.model, files=args.file, target=args.target, elapsed=elapsed)
    except Exception as e:
        elapsed = time.time() - t0
        fatal(f"Request failed: {e}", reason="request_failed", model=args.model, files=args.file, target=args.target, elapsed=elapsed)
    elapsed = time.time() - t0

    if args.verbose:
        print(f"[verbose] response ({elapsed:.2f}s):", file=sys.stderr)
        print(f"[verbose] {json.dumps(data, indent=2)[:2000]}", file=sys.stderr)

    # Extract response
    try:
        content = data["choices"][0]["message"]["content"]
    except (KeyError, IndexError):
        fatal(f"Unexpected response: {json.dumps(data)[:500]}", reason="unexpected_response", model=args.model, files=args.file, target=args.target, elapsed=elapsed)

    if not content:
        fatal("Empty response — model may have exhausted token budget on internal reasoning. "
              "Try increasing INTERN_MAX_TOKENS or use a non-reasoning model.",
              reason="empty_response", model=args.model, files=args.file, target=args.target, elapsed=elapsed)

    # Write to target file or stdout
    if args.target:
        target_dir = os.path.dirname(args.target)
        if target_dir:
            os.makedirs(target_dir, exist_ok=True)
        with open(args.target, "w") as f:
            f.write(content)
        print(f"Wrote {len(content)} bytes to {args.target}", file=sys.stderr)
    else:
        print(content)

    # Log usage stats — prefer actual cost from OpenRouter over our pricing table
    usage = data.get("usage", {})
    in_tok = usage.get("prompt_tokens", 0)
    out_tok = usage.get("completion_tokens", 0)
    actual_cost = usage.get("cost")
    log_usage(args.model, in_tok, out_tok, elapsed, actual_cost=actual_cost)
    log_event("success", "ok", model=args.model, files=args.file, target=args.target, elapsed=elapsed)
    print(f"[intern: {args.model} | {in_tok}in/{out_tok}out | {elapsed:.1f}s]", file=sys.stderr)
    if not args.target:
        print(
            "[intern: use direct narrow snippets for exact code/line numbers; do not re-ask ask-intern for verbatim source]",
            file=sys.stderr,
        )


if __name__ == "__main__":
    main()
