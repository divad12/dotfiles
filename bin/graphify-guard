#!/usr/bin/env python3
"""
Claude Code PreToolUse helper for Graphify.

When GRAPHIFY_GUARD_NUDGES=1 and a project already has graphify-out/graph.json,
nudge broad search commands toward the graph/report before raw grep-style
exploration. By default this hook only logs explicit graphify commands; Graphify
is an opt-in map, not an always-on reminder.
"""

import json
import hashlib
import os
import re
import shlex
import sys
import time
from pathlib import Path


SEARCH_RE = re.compile(r"(^|[;&|]\s*|\b)(rg|grep|ack|ag|ripgrep)\b")
VERIFICATION_RE = re.compile(
    r"\b(vitest|jest|mocha|playwright|tsc|npm\s+(?:run\s+)?test|pnpm\s+(?:run\s+)?test|yarn\s+(?:run\s+)?test)\b"
)
SEARCH_COMMANDS = {"rg", "grep", "ack", "ag", "ripgrep"}
FILE_EXT_RE = re.compile(r"\.[A-Za-z0-9_-]{1,8}$")
COMMON_DIRS = {"app", "docs", "lib", "packages", "prisma", "src", "test", "tests"}


def read_input():
    try:
        return json.load(sys.stdin)
    except json.JSONDecodeError:
        return {}


def state_dir():
    root = os.environ.get("GRAPHIFY_USAGE_DIR", "~/.config/graphify")
    path = Path(root).expanduser()
    path.mkdir(parents=True, exist_ok=True)
    return path


def config_bool(name, default=False):
    value = os.environ.get(name)
    if value is None:
        return default
    return value.lower() in {"1", "true", "yes", "on"}


def session_hash(session_id):
    return hashlib.sha256(session_id.encode("utf-8")).hexdigest()[:16] if session_id else ""


def nudge_state_path():
    return state_dir() / "nudges.json"


def load_nudge_state():
    try:
        data = json.loads(nudge_state_path().read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return {}
    return data if isinstance(data, dict) else {}


def save_nudge_state(state):
    path = nudge_state_path()
    tmp = path.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(tmp, path)


def tool_input_summary(record):
    tool_input = record.get("tool_input") or {}
    if not isinstance(tool_input, dict):
        return {}

    summary = {}
    for key in ("command", "file_path", "offset", "limit"):
        if key in tool_input:
            summary[key] = tool_input[key]
    return summary


def log_event(record, action, command="", root="", reason=""):
    event = {
        "ts": int(time.time()),
        "session": session_hash(record.get("session_id", "")),
        "source": "claude",
        "action": action,
        "reason": reason,
        "cwd": record.get("cwd", ""),
        "root": str(root) if root else "",
        "tool": record.get("tool_name", ""),
        "command": command,
        "hook_event_name": record.get("hook_event_name", ""),
        "tool_input": tool_input_summary(record),
    }
    try:
        with (state_dir() / "events.jsonl").open("a", encoding="utf-8") as f:
            f.write(json.dumps(event, sort_keys=True) + "\n")
    except OSError:
        pass


def is_graphify_command(command):
    try:
        tokens = shlex.split(command)
    except ValueError:
        tokens = command.split()
    return any(os.path.basename(token) == "graphify" for token in tokens)


def shell_tokens(segment):
    try:
        return shlex.split(segment)
    except ValueError:
        return segment.split()


def command_segments(command):
    return [segment.strip() for segment in re.split(r"\s*(?:&&|\|\||;)\s*", command) if segment.strip()]


def looks_like_file_path(token):
    token = token.rstrip(",")
    return bool(FILE_EXT_RE.search(token)) and not token.startswith("-")


def looks_like_directory_operand(token):
    if token.startswith("-") or looks_like_file_path(token):
        return False
    stripped = token.strip("'\"")
    parts = [part for part in Path(stripped).parts if part not in {"/", ".", "..", "~"}]
    return bool(parts and parts[0] in COMMON_DIRS)


def has_recursive_grep_flag(args):
    for token in args:
        if token == "--":
            break
        if not token.startswith("-") or token == "-":
            continue
        if "r" in token or "R" in token:
            return True
    return False


def search_segment_is_broad(segment):
    tokens = shell_tokens(segment)
    for index, token in enumerate(tokens):
        if os.path.basename(token) not in SEARCH_COMMANDS:
            continue
        command = os.path.basename(token)
        args = tokens[index + 1 :]
        if command == "grep" and has_recursive_grep_flag(args):
            return True
        has_file_operand = any(looks_like_file_path(arg) for arg in args)
        has_directory_operand = any(looks_like_directory_operand(arg) for arg in args)
        if has_file_operand and not has_directory_operand:
            return False
        return True
    return False


def is_broad_search_command(command):
    if VERIFICATION_RE.search(command):
        return False
    segments = [segment for segment in command_segments(command) if SEARCH_RE.search(segment)]
    return any(search_segment_is_broad(segment) for segment in segments)


def graph_root(cwd):
    start = Path(cwd or os.getcwd()).expanduser().resolve()
    for path in [start, *start.parents]:
        if (path / "graphify-out" / "graph.json").is_file():
            return path
    return None


def should_nudge(record, root):
    if not config_bool("GRAPHIFY_GUARD_NUDGES"):
        return False
    if config_bool("GRAPHIFY_GUARD_REPEAT_NUDGES"):
        return True

    key = f"{session_hash(record.get('session_id', ''))}:{Path(root).resolve()}"
    state = load_nudge_state()
    if key in state:
        return False
    state[key] = int(time.time())
    try:
        save_nudge_state(state)
    except OSError:
        pass
    return True


def main():
    record = read_input()
    if record.get("tool_name") != "Bash":
        return

    tool_input = record.get("tool_input") or {}
    if not isinstance(tool_input, dict):
        return

    command = tool_input.get("command", "")
    if not isinstance(command, str) or not SEARCH_RE.search(command):
        if isinstance(command, str) and is_graphify_command(command):
            log_event(record, "command", command=command)
        return
    if is_graphify_command(command):
        log_event(record, "command", command=command)
        return

    if not is_broad_search_command(command):
        return

    root = graph_root(record.get("cwd", ""))
    if root is None:
        return
    if not should_nudge(record, root):
        return

    report = root / "graphify-out" / "GRAPH_REPORT.md"
    wiki = root / "graphify-out" / "wiki" / "index.md"
    navigation = wiki if wiki.is_file() else report
    message = (
        "graphify: knowledge graph exists. Before broad raw search, use "
        "`graphify explain \"<exact node>\"`, concrete `graphify query \"<terms>\"`, or read "
        f"`{navigation}` for graph navigation, god nodes, and community structure. Then use ask-intern "
        "on the selected files if you still need bulk source summaries."
    )
    log_event(record, "nudge", command=command, root=root, reason="broad_search_in_graphified_repo")
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "additionalContext": message,
        }
    }))


if __name__ == "__main__":
    main()
