_DASHBOARD_SCRIPT = r"""
(function () {
  const decisions = [];
  const pendingSaves = [];
  const state = {
    activeTab: "inbox",
    activeConfidence: "all",
    query: "",
  };

  const toast = document.getElementById("toast");
  let toastTimer = 0;
  function showToast(message) {
    if (!toast) return;
    toast.hidden = false;
    toast.textContent = message;
    requestAnimationFrame(() => toast.classList.add("is-on"));
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => {
      toast.classList.remove("is-on");
      setTimeout(() => { toast.hidden = true; }, 220);
    }, 1600);
  }

  async function recordDecision(decision) {
    decisions.push(decision);
    const save = fetch("/decisions", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(decision),
    }).catch((error) => {
      console.warn("Save decisions.jsonl fallback needed", error);
    });
    pendingSaves.push(save);
    await save;
  }

  function markRecorded(button) {
    button.dataset.recorded = "true";
  }

  function markEntryDecided(card, label) {
    if (!card) return;
    card.classList.add("is-decided");
    showToast(label);
  }

  const ACTION_TOAST = {
    promote: "Adopted — will land at Finish",
    candidate: "Triaged — moves to Triaged at Finish",
    archive: "Archived",
    defer: "Snoozed",
    block: "Blocked",
    "follow-up": "Follow-up noted",
    "draft-plan": "Plan drafted at Finish",
    "draft-patch": "Patch drafted at Finish",
    calibration: "Rule recorded",
  };
  const PRIMARY_ACTIONS = new Set(["promote", "candidate", "archive", "defer"]);

  document.addEventListener("click", async (event) => {
    const button = event.target.closest("button[data-action]");
    if (!button || button.disabled) return;
    const action = button.dataset.action;
    const fingerprint = button.dataset.fingerprint || "global";
    const card = button.closest(".entry");
    let note = "";
    if (action === "calibration") {
      const calNote = document.getElementById("calibration-note");
      note = calNote ? calNote.value.trim() : "";
      if (!note) {
        showToast("Add a rule first");
        return;
      }
    } else {
      const noteBox = document.querySelector('[data-note-for="' + fingerprint + '"]');
      note = noteBox ? noteBox.value : "";
    }
    await recordDecision({ fingerprint, action, note });
    markRecorded(button);
    if (PRIMARY_ACTIONS.has(action) && card) {
      markEntryDecided(card, ACTION_TOAST[action] || "Recorded");
    } else {
      showToast(ACTION_TOAST[action] || "Recorded");
    }
    if (action === "calibration") {
      const calNote = document.getElementById("calibration-note");
      if (calNote) calNote.value = "";
    }
  });

  // Tabs
  const mainEl = document.querySelector("main");
  document.querySelectorAll('[role="tab"]').forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = tab.dataset.tab;
      state.activeTab = target;
      document.querySelectorAll('[role="tab"]').forEach((t) => {
        t.setAttribute("aria-selected", t === tab ? "true" : "false");
      });
      document.querySelectorAll("[data-panel]").forEach((panel) => {
        panel.hidden = panel.dataset.panel !== target;
      });
      if (mainEl) mainEl.dataset.activeTab = target;
      tab.scrollIntoView({ block: "nearest", inline: "nearest" });
    });
  });
  if (mainEl) mainEl.dataset.activeTab = "inbox";

  // Filter chips
  document.querySelectorAll(".filter-chips .chip").forEach((chip) => {
    chip.addEventListener("click", () => {
      state.activeConfidence = chip.dataset.conf;
      document.querySelectorAll(".filter-chips .chip").forEach((c) => {
        const active = c === chip;
        c.classList.toggle("is-active", active);
        c.setAttribute("aria-pressed", active ? "true" : "false");
      });
      applyFilters();
    });
  });

  // Search
  const searchInput = document.getElementById("search");
  if (searchInput) {
    searchInput.addEventListener("input", () => {
      state.query = searchInput.value.trim().toLowerCase();
      applyFilters();
    });
  }

  function applyFilters() {
    document.querySelectorAll(".entry").forEach((card) => {
      const conf = card.dataset.confidence || "low";
      const search = card.dataset.search || "";
      const confOk = state.activeConfidence === "all" || conf === state.activeConfidence;
      const queryOk = !state.query || search.indexOf(state.query) !== -1;
      card.hidden = !(confOk && queryOk);
    });
  }

  // Export
  function jsonl(decision) { return JSON.stringify(decision) + "\n"; }
  const exportBtn = document.getElementById("export");
  if (exportBtn) {
    exportBtn.addEventListener("click", () => {
      if (!decisions.length) {
        showToast("No decisions to export yet");
        return;
      }
      const text = decisions.map(jsonl).join("");
      const blob = new Blob([text], { type: "application/jsonl" });
      const anchor = document.createElement("a");
      anchor.href = URL.createObjectURL(blob);
      anchor.download = "decisions.jsonl";
      anchor.click();
      URL.revokeObjectURL(anchor.href);
      showToast("Exported decisions.jsonl");
    });
  }

  async function finishReview() {
    await Promise.allSettled(pendingSaves);
    await fetch("/finish", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ action: "finish" }),
    }).catch(() => {});
  }

  const finishBtn = document.getElementById("finish");
  if (finishBtn) {
    finishBtn.addEventListener("click", async () => {
      finishBtn.disabled = true;
      finishBtn.textContent = "Finishing…";
      await finishReview();
      showToast("All decisions executed");
    });
  }

  // Keyboard: j/k to navigate cards within active panel, Enter to expand
  document.addEventListener("keydown", (event) => {
    if (event.target && /input|textarea/i.test(event.target.tagName || "")) return;
    if (event.metaKey || event.ctrlKey || event.altKey) return;
    const visible = Array.from(document.querySelectorAll("[data-panel]:not([hidden]) .entry"))
      .filter((card) => !card.hidden);
    if (!visible.length) return;
    const current = document.activeElement && document.activeElement.closest(".entry");
    let index = visible.indexOf(current);
    if (event.key === "j" || event.key === "ArrowDown") {
      event.preventDefault();
      index = Math.min(visible.length - 1, index + 1);
      if (index < 0) index = 0;
      visible[index].focus({ preventScroll: false });
      visible[index].scrollIntoView({ block: "nearest" });
    } else if (event.key === "k" || event.key === "ArrowUp") {
      event.preventDefault();
      index = index <= 0 ? 0 : index - 1;
      visible[index].focus({ preventScroll: false });
      visible[index].scrollIntoView({ block: "nearest" });
    } else if (event.key === "Enter" && current) {
      const body = current.querySelector("details.entry-body");
      if (body) {
        event.preventDefault();
        body.open = !body.open;
      }
    }
  });

  // Make entries focusable for keyboard nav
  document.querySelectorAll(".entry").forEach((card) => {
    if (!card.hasAttribute("tabindex")) card.setAttribute("tabindex", "-1");
  });
})();
"""


def serve_dashboard(store: Path, host: str, port: int, execute_on_finish: bool) -> None:
    class Handler(BaseHTTPRequestHandler):
        def log_message(self, format: str, *args: object) -> None:
            return

        def do_GET(self) -> None:
            if self.path not in {"/", "/dashboard.html"}:
                self.send_error(404)
                return
            data = (store / "dashboard.html").read_bytes()
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)

        def do_POST(self) -> None:
            if self.path == "/finish":
                if execute_on_finish:
                    execute_pending_decisions(store)
                    write_dashboard(store)
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(b'{"ok": true, "finished": true}')
                append_audit(store, "dashboard: finish received")
                import threading

                threading.Thread(target=self.server.shutdown, daemon=True).start()
                return
            if self.path != "/decisions":
                self.send_error(404)
                return
            length = int(self.headers.get("Content-Length", "0"))
            payload = self.rfile.read(length)
            decision = json.loads(payload.decode("utf-8"))
            with (store / "decisions.jsonl").open("a") as handle:
                handle.write(json.dumps(decision, sort_keys=True) + "\n")
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(b'{"ok": true}')

    server = ThreadingHTTPServer((host, port), Handler)
    actual_host, actual_port = server.server_address
    print(f"http://{actual_host}:{actual_port}", flush=True)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()


def command_execute(args: argparse.Namespace) -> int:
    store = init_store(args.repo)
    execute_pending_decisions(store)
    print("executed decisions")
    return 0


def execute_pending_decisions(store: Path) -> None:
    decisions = store / "decisions.jsonl"
    for line in decisions.read_text().splitlines():
        if not line.strip():
            continue
        decision = json.loads(line)
        execute_decision(store, decision)
    decisions.write_text("")


def execute_decision(store: Path, decision: dict[str, str]) -> None:
    action = decision.get("action", "")
    fingerprint = decision.get("fingerprint", "")
    note = decision.get("note", "")
    value = decision.get("value", "")
    append_audit(
        store,
        "decision: {action} {fingerprint} {note}".format(
            action=action,
            fingerprint=fingerprint,
            note=note,
        ).rstrip(),
    )
    if action == "archive":
        archive_entry(store, fingerprint, note)
    elif action in {"candidate", "promote"}:
        if code_related_entry(store, fingerprint):
            marker = f"TDD/review required before {action}: {note}".rstrip()
            append_open_entry_labeled_note(store, fingerprint, "Follow-up task", marker)
            append_audit(store, f"follow-up: {fingerprint} TDD/review required before {action}")
            return
        status = "promoted" if action == "promote" else "candidate"
        move_entry_to_candidates(store, fingerprint, status, note, action)
    elif action == "revise-wording" and value:
        if update_open_entry_field(store, fingerprint, "User-facing summary", value):
            append_audit(store, f"revise-wording: {fingerprint} {note}".rstrip())
    elif action == "follow-up":
        if append_open_entry_labeled_note(store, fingerprint, "Follow-up task", note):
            append_audit(store, f"follow-up: {fingerprint} {note}".rstrip())
    elif action == "draft-plan":
        marker = f"Draft plan requested: {note}".rstrip()
        if append_open_entry_labeled_note(store, fingerprint, "Follow-up task", marker):
            draft_path = write_draft_artifact(store, fingerprint, "plan", note)
            if draft_path:
                append_open_entry_labeled_note(store, fingerprint, "Draft plan", draft_path)
                append_audit(store, f"draft-plan: {fingerprint} wrote {draft_path}")
            append_audit(store, f"draft-plan: {fingerprint} TDD/review task marker created")
    elif action == "draft-patch":
        marker = f"Draft patch requested: {note}".rstrip()
        if append_open_entry_labeled_note(store, fingerprint, "Follow-up task", marker):
            draft_path = write_draft_artifact(store, fingerprint, "patch", note)
            if draft_path:
                append_open_entry_labeled_note(store, fingerprint, "Draft patch", draft_path)
                append_audit(store, f"draft-patch: {fingerprint} wrote {draft_path}")
            append_audit(store, f"draft-patch: {fingerprint} TDD/review task marker created")
    elif action == "confidence" and value in VALID_CONFIDENCE:
        if update_open_entry_field(store, fingerprint, "Confidence", value):
            append_audit(store, f"confidence: {fingerprint} {value} {note}".rstrip())
    elif action == "prevention-artifact" and value:
        block = open_entry_block(store, fingerprint)
        current = block_artifacts(block) if block else []
        artifacts = unique_prevention_artifacts(current + [value])
        if update_open_entry_field(
            store, fingerprint, "Prevention artifacts", format_prevention_artifacts(artifacts)
        ):
            block = open_entry_block(store, fingerprint)
            if block and requires_tdd_review(block):
                update_open_entry_field(store, fingerprint, "Requires TDD/review", "yes")
            append_audit(store, f"prevention-artifact: {fingerprint} {value} {note}".rstrip())
    elif action == "prevention-artifacts" and value:
        artifacts = parse_prevention_artifacts(value)
        if update_open_entry_field(
            store, fingerprint, "Prevention artifacts", format_prevention_artifacts(artifacts)
        ):
            block = open_entry_block(store, fingerprint)
            if block and requires_tdd_review(block):
                update_open_entry_field(store, fingerprint, "Requires TDD/review", "yes")
            append_audit(store, f"prevention-artifacts: {fingerprint} {value} {note}".rstrip())
    elif action == "calibration":
        with (store / "calibration.md").open("a") as calibration:
            calibration.write(f"- {fingerprint}: {note}\n")
        append_audit(store, f"calibration: {fingerprint} {note}".rstrip())
    elif action == "block":
        if update_open_entry_field(store, fingerprint, "Status", "blocked"):
            append_open_entry_note(store, fingerprint, note or action)
            append_audit(store, f"block: {fingerprint} {note}".rstrip())
    elif action in {"note", "defer"}:
        if append_open_entry_note(store, fingerprint, note or action):
            append_audit(store, f"{action}: {fingerprint} {note}".rstrip())
    else:
        append_audit(store, f"decision ignored: {action} {fingerprint}".rstrip())


def command_promote(args: argparse.Namespace) -> int:
    store = init_store(args.repo)
    promoted = 0
    for _, block in list(iter_open_entries(store)):
        fingerprint = entry_fingerprint(block)
        artifacts = block_artifacts(block)
        required_names = required_artifact_names(artifacts)
        confidence = entry_field(block, "Confidence")
        if entry_field(block, "Status") != "inbox":
            continue
        if requires_tdd_review(block):
            append_open_entry_labeled_note(
                store,
                fingerprint,
                "Follow-up task",
                "follow-up required before code changes",
            )
            if move_entry_to_candidates(
                store,
                fingerprint,
                "candidate",
                "follow-up required before code changes",
            ):
                append_audit(
                    store,
                    f"auto-promote: candidate {fingerprint} follow-up required before code changes",
                )
                promoted += 1
        elif "archive" in required_names:
            if archive_entry(store, fingerprint, "auto-promotion archived archive-targeted learning"):
                append_audit(store, f"auto-promote: archive {fingerprint}")
                promoted += 1
        elif confidence == "high" and required_names and all(
            artifact in NON_CODE_AUTO_CANDIDATES for artifact in required_names
        ):
            if move_entry_to_candidates(store, fingerprint, "candidate", "auto-promotion docs candidate"):
                append_audit(store, f"auto-promote: candidate {fingerprint}")
                promoted += 1
    print(f"promoted {promoted} learning(s)")
    return 0


def command_check_merge(args: argparse.Namespace) -> int:
    store = init_store(args.repo)
    high_confidence = 0
    for path in open_entry_paths(store):
        for line in path.read_text().splitlines():
            if line == "- Confidence: high":
                high_confidence += 1
    if high_confidence:
        print(
            f"Learning check: {high_confidence} high-confidence item(s) need review before landing."
        )
        return 1
    print("Learning check: no high-confidence open items found.")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Manage the local learning store.")
    parser.add_argument("--repo", type=Path, default=Path.cwd())
    subparsers = parser.add_subparsers(dest="command")

    init_parser = subparsers.add_parser("init")
    init_parser.set_defaults(func=command_init)

    learn_init_parser = subparsers.add_parser("learn-init")
    learn_init_parser.set_defaults(func=command_init)

    capture_parser = subparsers.add_parser("capture")
    capture_parser.add_argument("--source", required=True)
    capture_parser.add_argument("--source-event", action="append", default=[])
    capture_parser.add_argument("--scope", default="project")
    capture_parser.add_argument("--summary", required=True)
    capture_parser.add_argument("--evidence", required=True)
    capture_parser.add_argument("--technical-ref", action="append", default=[])
    capture_parser.add_argument("--ramification", required=True)
    capture_parser.add_argument("--suspected-pattern", default="")
    capture_parser.add_argument("--recommended-fix", required=True)
    capture_parser.add_argument("--prevention-artifact", action="append", required=True)
    capture_parser.add_argument(
        "--confidence", choices=sorted(VALID_CONFIDENCE), default="medium"
    )
    capture_parser.set_defaults(func=command_capture)

    dashboard_parser = subparsers.add_parser("dashboard")
    dashboard_parser.add_argument("--serve", action="store_true")
    dashboard_parser.add_argument("--execute-on-finish", action="store_true")
    dashboard_parser.add_argument("--host", default="127.0.0.1")
    dashboard_parser.add_argument("--port", type=int, default=8000)
    dashboard_parser.set_defaults(func=command_dashboard)

    execute_parser = subparsers.add_parser("execute")
    execute_parser.set_defaults(func=command_execute)

    promote_parser = subparsers.add_parser("promote")
    promote_parser.set_defaults(func=command_promote)

    check_merge_parser = subparsers.add_parser("check-merge")
    check_merge_parser.set_defaults(func=command_check_merge)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    args.repo = resolve_repo(args.repo)
    if not hasattr(args, "func"):
        args.func = command_dashboard
        args.serve = False
        args.execute_on_finish = False
        args.host = "127.0.0.1"
        args.port = 8000
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
