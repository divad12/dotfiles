#!/usr/bin/env python3
import argparse
import hashlib
import html
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
import json
import re
from dataclasses import dataclass, field
from datetime import date
from pathlib import Path


STORE_FILES = {
    "README.md": "# Project Learnings\n\nThis directory is the repo-local store for the global learning system.\n\nCanonical operating contract: dotfiles `docs/ai/learning-system.md` and the global `/learn`, `/dashboard`, and `/learn-init` skills.\n\nDo not duplicate workflow rules here; keep this file as a pointer.\n",
    "inbox.md": "# Learning Inbox\n\n",
    "candidates.md": "# Learning Candidates\n\n",
    "dashboard.md": "# Learning Dashboard\n\n",
    "calibration.md": "# Learning Calibration\n\n",
    "auto-actions.md": "# Learning Auto-Actions\n\n",
    "decisions.jsonl": "",
}


VALID_CONFIDENCE = {"low", "medium", "high"}
CONFIDENCE_RANK = {"low": 0, "medium": 1, "high": 2}
NON_ENTRY_MARKDOWN = {"README.md", "dashboard.md", "calibration.md", "auto-actions.md"}
CODE_ARTIFACTS = {
    "test",
    "lint",
    "helper",
    "skill",
    "nested-AGENTS",
    "automation",
    "code",
    "enforcement",
    "architecture",
}
NON_CODE_AUTO_CANDIDATES = {"docs"}
ENTRY_HEADING = re.compile(r"^### [0-9a-f]{12}-.*$", re.MULTILINE)


@dataclass
class LearningEntry:
    source: str
    summary: str
    evidence: str
    ramification: str
    recommended_fix: str
    prevention_artifacts: list[str]
    confidence: str = "medium"
    captured: str = field(default_factory=lambda: date.today().isoformat())
    source_events: list[str] = field(default_factory=list)
    scope: str = "project"
    suspected_pattern: str = ""
    technical_refs: list[str] = field(default_factory=list)
    status: str = "inbox"

    @property
    def fingerprint(self) -> str:
        normalized = "|".join(
            [
                " ".join(self.summary.lower().split()),
                " ".join(self.suspected_pattern.lower().split()),
                "|".join(sorted(ref.strip() for ref in self.technical_refs if ref.strip())),
            ]
        )
        return hashlib.sha1(normalized.encode("utf-8")).hexdigest()[:12]


def store_dir(repo: Path) -> Path:
    return repo / "docs" / "learnings"


def resolve_repo(repo: Path) -> Path:
    resolved = repo.resolve()
    current = resolved.parent if resolved.is_file() else resolved
    for candidate in [current, *current.parents]:
        if (candidate / ".git").exists():
            return candidate
    return resolved


def init_store(repo: Path) -> Path:
    store = store_dir(repo)
    store.mkdir(parents=True, exist_ok=True)
    (store / "archive").mkdir(exist_ok=True)
    for filename, content in STORE_FILES.items():
        path = store / filename
        if not path.exists():
            path.write_text(content)
    return store


def format_entry(entry: LearningEntry) -> str:
    source_events = ", ".join(entry.source_events) if entry.source_events else "None"
    technical_refs = ", ".join(entry.technical_refs) if entry.technical_refs else "None"
    suspected_pattern = entry.suspected_pattern or "Unknown"
    prevention_artifacts = unique_prevention_artifacts(entry.prevention_artifacts)
    needs_tdd_review = artifacts_require_tdd(prevention_artifacts)
    return "\n".join(
        [
            f"### {entry.fingerprint}-{slugify(entry.summary)}",
            f"- Fingerprint: {entry.fingerprint}",
            f"- Sources: {entry.source}",
            f"- Captured: {entry.captured}",
            f"- Source events: {source_events}",
            f"- Scope: {entry.scope}",
            f"- User-facing summary: {entry.summary}",
            f"- Evidence: {entry.evidence}",
            f"- Technical refs: {technical_refs}",
            f"- Ramification: {entry.ramification}",
            f"- Suspected pattern: {suspected_pattern}",
            f"- Recommended fix: {entry.recommended_fix}",
            f"- Prevention artifacts: {format_prevention_artifacts(prevention_artifacts)}",
            *(
                ["- Requires TDD/review: yes"]
                if needs_tdd_review
                else []
            ),
            f"- Confidence: {entry.confidence}",
            f"- Status: {entry.status}",
            "",
        ]
    )


def slugify(value: str) -> str:
    chars = [char.lower() if char.isalnum() else "-" for char in value]
    return "-".join("".join(chars).split("-"))[:64]


def unique_values(values: list[str]) -> list[str]:
    seen: set[str] = set()
    unique: list[str] = []
    for value in values:
        normalized = value.strip()
        if not normalized or normalized in seen:
            continue
        seen.add(normalized)
        unique.append(normalized)
    return unique


def normalize_prevention_artifact(value: str) -> str:
    stripped = value.strip()
    if not stripped:
        return ""
    match = re.match(
        r"^(.+?)\s*(?:\((required|proposed)\)|[|:](required|proposed))$",
        stripped,
    )
    if match:
        artifact = match.group(1).strip()
        status = (match.group(2) or match.group(3) or "required").strip()
    else:
        artifact = stripped
        status = "required"
    return f"{artifact} ({status})"


def unique_prevention_artifacts(values: list[str]) -> list[str]:
    return unique_values(
        [
            normalized
            for normalized in (normalize_prevention_artifact(value) for value in values)
            if normalized
        ]
    )


def parse_prevention_artifacts(value: str) -> list[str]:
    return unique_prevention_artifacts(value.split(","))


def format_prevention_artifacts(values: list[str]) -> str:
    return ", ".join(unique_prevention_artifacts(values))


def prevention_artifact_parts(value: str) -> tuple[str, str]:
    normalized = normalize_prevention_artifact(value)
    match = re.match(r"^(.+?) \((required|proposed)\)$", normalized)
    if not match:
        return normalized, "required"
    return match.group(1), match.group(2)


def required_artifact_names(artifacts: list[str]) -> list[str]:
    return [
        name
        for name, status in (prevention_artifact_parts(artifact) for artifact in artifacts)
        if status == "required"
    ]


def artifacts_require_tdd(artifacts: list[str]) -> bool:
    return any(name in CODE_ARTIFACTS for name in required_artifact_names(artifacts))


def block_artifacts(block: str) -> list[str]:
    return parse_prevention_artifacts(entry_field(block, "Prevention artifacts"))


def merge_sources(line: str, source: str) -> str:
    prefix = "- Sources: "
    current = [item.strip() for item in line.removeprefix(prefix).split(",") if item.strip()]
    if source not in current:
        current.append(source)
    return prefix + ", ".join(current)


def merge_existing_entry(markdown: str, entry: LearningEntry) -> str:
    fingerprint_line = f"- Fingerprint: {entry.fingerprint}"
    preamble, blocks = split_entry_blocks(markdown)
    for index, block in enumerate(blocks):
        if fingerprint_line not in block:
            continue
        blocks[index] = merge_entry_block(block, entry)
        content = preamble.rstrip() + "\n\n"
        for merged_block in blocks:
            content += merged_block.rstrip() + "\n"
        return content

    start = markdown.find(fingerprint_line)
    if start == -1:
        return markdown

    block_start = markdown.rfind("\n### ", 0, start)
    if block_start == -1:
        block_start = 0
    else:
        block_start += 1
    next_entry = markdown.find("\n### ", start)
    block_end = len(markdown) if next_entry == -1 else next_entry

    block = markdown[block_start:block_end]
    merged_block = merge_entry_block(block, entry)
    return markdown[:block_start] + merged_block + markdown[block_end:]


def merge_entry_block(block: str, entry: LearningEntry) -> str:
    lines = block.splitlines()
    merged_lines = [
        merge_sources(line, entry.source) if line.startswith("- Sources: ") else line
        for line in lines
    ]
    merged_block = "\n".join(merged_lines) + "\n"
    evidence_line = f"- Additional evidence: {entry.evidence}"
    if evidence_line not in merged_block.splitlines():
        merged_block = append_entry_note(merged_block, "Additional evidence", entry.evidence)
    merged_block = set_entry_field(merged_block, "Captured", entry.captured)
    current_artifacts = block_artifacts(merged_block)
    incoming_artifacts = unique_prevention_artifacts(entry.prevention_artifacts)
    prevention_artifacts = (
        incoming_artifacts
        if "archive" in required_artifact_names(current_artifacts)
        and "archive" not in required_artifact_names(incoming_artifacts)
        else unique_prevention_artifacts(current_artifacts + incoming_artifacts)
    )
    merged_block = set_entry_field(
        merged_block,
        "Prevention artifacts",
        format_prevention_artifacts(prevention_artifacts),
    )
    merged_block = set_entry_field(merged_block, "Recommended fix", entry.recommended_fix)
    if should_raise_confidence(entry_field(merged_block, "Confidence"), entry.confidence):
        merged_block = set_entry_field(merged_block, "Confidence", entry.confidence)
    if requires_tdd_review(merged_block):
        merged_block = set_entry_field(merged_block, "Requires TDD/review", "yes")
    return merged_block


def should_raise_confidence(current: str, incoming: str) -> bool:
    return CONFIDENCE_RANK.get(incoming, -1) > CONFIDENCE_RANK.get(current, -1)


def split_entry_blocks(markdown: str) -> tuple[str, list[str]]:
    matches = list(ENTRY_HEADING.finditer(markdown))
    if not matches:
        return markdown, []
    preamble = markdown[: matches[0].start()]
    blocks: list[str] = []
    for index, match in enumerate(matches):
        end = matches[index + 1].start() if index + 1 < len(matches) else len(markdown)
        blocks.append(markdown[match.start() : end].strip() + "\n")
    return preamble, blocks


def write_entry_blocks(path: Path, preamble: str, blocks: list[str]) -> None:
    content = preamble.rstrip() + "\n\n"
    for block in blocks:
        content += block.rstrip() + "\n"
    path.write_text(content)


def entry_field(block: str, label: str) -> str:
    prefix = f"- {label}: "
    for line in block.splitlines():
        if line.startswith(prefix):
            return line.removeprefix(prefix)
    return ""


def entry_field_multiline(block: str, label: str) -> str:
    prefix = f"- {label}: "
    lines = block.splitlines()
    for index, line in enumerate(lines):
        if not line.startswith(prefix):
            continue
        values = [line.removeprefix(prefix)]
        for continuation in lines[index + 1 :]:
            if continuation.startswith("- "):
                break
            values.append(continuation)
        return "\n".join(values).strip()
    return ""


def entry_fields(block: str, label: str) -> list[str]:
    prefix = f"- {label}: "
    return [
        line.removeprefix(prefix)
        for line in block.splitlines()
        if line.startswith(prefix)
    ]


def entry_fingerprint(block: str) -> str:
    return entry_field(block, "Fingerprint")


def set_entry_field(block: str, label: str, value: str) -> str:
    prefix = f"- {label}: "
    lines = block.rstrip().splitlines()
    for index, line in enumerate(lines):
        if line.startswith(prefix):
            lines[index] = prefix + value
            return "\n".join(lines) + "\n"
    insert_at = len(lines)
    for index, line in enumerate(lines):
        if line.startswith("- Status: "):
            insert_at = index
            break
    lines.insert(insert_at, prefix + value)
    return "\n".join(lines) + "\n"


def append_entry_note(block: str, label: str, value: str) -> str:
    line = f"- {label}: {value}"
    lines = block.rstrip().splitlines()
    if line not in lines:
        insert_at = len(lines)
        for index, existing in enumerate(lines):
            if existing.startswith("- Status: "):
                insert_at = index
                break
        lines.insert(insert_at, line)
    return "\n".join(lines) + "\n"


def find_open_entry(store: Path, fingerprint: str) -> tuple[Path, str, list[str], int] | None:
    for path in open_entry_paths(store):
        preamble, blocks = split_entry_blocks(path.read_text())
        for index, block in enumerate(blocks):
            if entry_fingerprint(block) == fingerprint:
                return path, preamble, blocks, index
    return None


def remove_open_entry(store: Path, fingerprint: str) -> str | None:
    found = find_open_entry(store, fingerprint)
    if not found:
        return None
    path, preamble, blocks, index = found
    block = blocks.pop(index)
    write_entry_blocks(path, preamble, blocks)
    return block


def replace_open_entry(store: Path, fingerprint: str, block: str) -> bool:
    found = find_open_entry(store, fingerprint)
    if not found:
        return False
    path, preamble, blocks, index = found
    blocks[index] = block
    write_entry_blocks(path, preamble, blocks)
    return True


def append_to_entry_file(path: Path, block: str) -> None:
    preamble, blocks = split_entry_blocks(path.read_text())
    fingerprint = entry_fingerprint(block)
    blocks = [existing for existing in blocks if entry_fingerprint(existing) != fingerprint]
    blocks.append(block)
    write_entry_blocks(path, preamble, blocks)


def archive_entry(store: Path, fingerprint: str, note: str = "") -> bool:
    block = remove_open_entry(store, fingerprint)
    if block is None:
        return False
    block = set_entry_field(block, "Status", "archived")
    if note:
        block = append_entry_note(block, "Decision note", note)
    archive = store / "archive"
    archive.mkdir(exist_ok=True)
    summary_slug = slugify(entry_field(block, "User-facing summary")) or fingerprint
    archive_path = archive / f"{fingerprint}-{summary_slug}.md"
    archive_path.write_text("# Archived Learning\n\n" + block)
    append_audit(store, f"archive: {fingerprint} {note}".rstrip())
    return True


def move_entry_to_candidates(
    store: Path, fingerprint: str, status: str, note: str = "", audit_action: str | None = None
) -> bool:
    block = remove_open_entry(store, fingerprint)
    if block is None:
        return False
    block = set_entry_field(block, "Status", status)
    if note:
        block = append_entry_note(block, "Decision note", note)
    append_to_entry_file(store / "candidates.md", block)
    append_audit(store, f"{audit_action or status}: {fingerprint} {note}".rstrip())
    return True


def update_open_entry_field(store: Path, fingerprint: str, label: str, value: str) -> bool:
    found = find_open_entry(store, fingerprint)
    if not found:
        return False
    path, preamble, blocks, index = found
    blocks[index] = set_entry_field(blocks[index], label, value)
    write_entry_blocks(path, preamble, blocks)
    return True


def append_open_entry_note(store: Path, fingerprint: str, note: str) -> bool:
    return append_open_entry_labeled_note(store, fingerprint, "Decision note", note)


def append_open_entry_labeled_note(
    store: Path, fingerprint: str, label: str, note: str
) -> bool:
    found = find_open_entry(store, fingerprint)
    if not found:
        return False
    path, preamble, blocks, index = found
    blocks[index] = append_entry_note(blocks[index], label, note)
    write_entry_blocks(path, preamble, blocks)
    return True


def code_related_entry(store: Path, fingerprint: str) -> bool:
    found = find_open_entry(store, fingerprint)
    if not found:
        return False
    _, _, blocks, index = found
    return requires_tdd_review(blocks[index])


def requires_tdd_review(block: str) -> bool:
    return (
        entry_field(block, "Requires TDD/review").lower() == "yes"
        or artifacts_require_tdd(block_artifacts(block))
    )


def open_entry_block(store: Path, fingerprint: str) -> str | None:
    found = find_open_entry(store, fingerprint)
    if not found:
        return None
    _, _, blocks, index = found
    return blocks[index]


def write_draft_artifact(store: Path, fingerprint: str, kind: str, note: str) -> str | None:
    block = open_entry_block(store, fingerprint)
    if block is None:
        return None
    drafts = store / "drafts"
    drafts.mkdir(exist_ok=True)
    relative_path = Path("drafts") / f"{fingerprint}-{kind}.md"
    draft_path = store / relative_path
    artifacts = entry_field(block, "Prevention artifacts")
    warning = ""
    if requires_tdd_review(block):
        warning = (
            "\n## TDD/Review Warning\n"
            "TDD/review required before code, shared skill, enforcement, or architecture changes.\n"
        )
    draft_path.write_text(
        "\n".join(
            [
                f"# Draft {kind.title()}",
                "",
                f"- Fingerprint: {fingerprint}",
                f"- User-facing summary: {entry_field(block, 'User-facing summary')}",
                f"- Evidence: {entry_field_multiline(block, 'Evidence')}",
                f"- Ramification: {entry_field(block, 'Ramification')}",
                f"- Recommended fix: {entry_field(block, 'Recommended fix')}",
                f"- Technical refs: {entry_field(block, 'Technical refs')}",
                f"- Prevention artifacts: {artifacts}",
                f"- Dashboard note: {note}",
                warning.rstrip(),
                "",
            ]
        )
    )
    return str(relative_path)


def iter_open_entries(store: Path) -> list[tuple[Path, str]]:
    entries: list[tuple[Path, str]] = []
    for path in open_entry_paths(store):
        _, blocks = split_entry_blocks(path.read_text())
        for block in blocks:
            if entry_fingerprint(block):
                entries.append((path, block))
    return entries


def append_audit(store: Path, line: str) -> None:
    with (store / "auto-actions.md").open("a") as audit:
        audit.write(line + "\n")


def entry_paths(store: Path) -> list[Path]:
    paths: list[Path] = []
    for name in ["inbox.md", "candidates.md"]:
        path = store / name
        if path.exists():
            paths.append(path)

    archive = store / "archive"
    if archive.exists():
        paths.extend(sorted(archive.rglob("*.md")))

    for path in sorted(store.glob("*.md")):
        if path.name in NON_ENTRY_MARKDOWN or path in paths:
            continue
        paths.append(path)
    return paths


def open_entry_paths(store: Path) -> list[Path]:
    archive = store / "archive"
    return [
        path
        for path in entry_paths(store)
        if not (archive.exists() and path.is_relative_to(archive))
    ]


def append_entry(store: Path, entry: LearningEntry) -> tuple[str, str]:
    fingerprint = entry.fingerprint
    archive = store / "archive"
    for path in entry_paths(store):
        markdown = path.read_text()
        if f"- Fingerprint: {fingerprint}" in markdown:
            if archive.exists() and path.is_relative_to(archive):
                reopened_markdown = merge_existing_entry(markdown, entry)
                _, blocks = split_entry_blocks(reopened_markdown)
                for block in blocks:
                    if entry_fingerprint(block) != fingerprint:
                        continue
                    block = set_entry_field(block, "Status", "inbox")
                    append_to_entry_file(store / "inbox.md", block)
                    append_audit(store, f"reopen: {fingerprint} merged source {entry.source}")
                    return fingerprint, "updated"
            path.write_text(merge_existing_entry(markdown, entry))
            append_audit(store, f"exact-replay: {fingerprint} merged source {entry.source}")
            return fingerprint, "updated"

    inbox = store / "inbox.md"
    markdown = inbox.read_text()
    with inbox.open("a") as handle:
        if markdown and not markdown.endswith("\n"):
            handle.write("\n")
        handle.write(format_entry(entry))
    return fingerprint, "captured"


def command_init(args: argparse.Namespace) -> int:
    init_store(args.repo)
    print(f"initialized {store_dir(args.repo)}")
    return 0


def command_capture(args: argparse.Namespace) -> int:
    store = init_store(args.repo)
    entry = LearningEntry(
        source=args.source,
        summary=args.summary,
        evidence=args.evidence,
        ramification=args.ramification,
        recommended_fix=args.recommended_fix,
        prevention_artifacts=args.prevention_artifact,
        confidence=args.confidence,
        source_events=args.source_event,
        scope=args.scope,
        suspected_pattern=args.suspected_pattern,
        technical_refs=args.technical_ref,
    )
    fingerprint, action = append_entry(store, entry)
    print(f"{action} {fingerprint}")
    return 0


def command_dashboard(args: argparse.Namespace) -> int:
    store = init_store(args.repo)
    write_dashboard(store)
    if args.serve:
        serve_dashboard(store, args.host, args.port, args.execute_on_finish)
        return 0
    print(f"wrote {store / 'dashboard.md'}")
    return 0


def write_dashboard(store: Path) -> None:
    sections = ["# Learning Dashboard", ""]
    for path in open_entry_paths(store):
        sections.extend([f"## {path.relative_to(store)}", "", path.read_text(), ""])
    markdown = "\n".join(sections)
    (store / "dashboard.md").write_text(markdown)

    entries = [
        entry_to_dashboard_dict(store, path, block)
        for path, block in (*iter_open_entries(store), *iter_archived_entries(store))
    ]
    (store / "dashboard.html").write_text(
        render_dashboard_html(
            entries,
            dashboard_signals(store),
            calibration_items(store),
        )
    )


def entry_to_dashboard_dict(store: Path, path: Path, block: str) -> dict[str, object]:
    captured = entry_field(block, "Captured")
    return {
        "path": str(path.relative_to(store)),
        "fingerprint": entry_fingerprint(block),
        "summary": entry_field(block, "User-facing summary"),
        "ramification": entry_field(block, "Ramification"),
        "evidence": entry_field_multiline(block, "Evidence"),
        "additional_evidence": entry_fields(block, "Additional evidence"),
        "technical_refs": entry_field(block, "Technical refs"),
        "prevention_artifacts": entry_field(block, "Prevention artifacts"),
        "confidence": entry_field(block, "Confidence"),
        "status": entry_field(block, "Status"),
        "recommended_fix": entry_field(block, "Recommended fix"),
        "decision_notes": entry_fields(block, "Decision note"),
        "follow_up_tasks": entry_fields(block, "Follow-up task"),
        "draft_plans": entry_fields(block, "Draft plan"),
        "draft_patches": entry_fields(block, "Draft patch"),
        "captured": captured,
        "captured_relative": relative_captured(captured),
        "sources": entry_field(block, "Sources"),
        "source_events": entry_field(block, "Source events"),
        "scope": entry_field(block, "Scope"),
        "suspected_pattern": entry_field(block, "Suspected pattern"),
        "is_aging": entry_is_aging(block),
    }


def iter_archived_entries(store: Path) -> list[tuple[Path, str]]:
    archive = store / "archive"
    if not archive.exists():
        return []
    entries: list[tuple[Path, str]] = []
    for path in sorted(archive.glob("*.md")):
        _, blocks = split_entry_blocks(path.read_text())
        for block in blocks:
            if entry_fingerprint(block):
                entries.append((path, block))
    return entries


def calibration_items(store: Path) -> list[str]:
    path = store / "calibration.md"
    if not path.exists():
        return []
    items: list[str] = []
    for line in path.read_text().splitlines():
        if line.startswith("- "):
            stripped = line.removeprefix("- ").strip()
            if stripped:
                items.append(stripped)
    return items


def relative_captured(value: str, today: date | None = None) -> str:
    if not value:
        return ""
    try:
        captured = date.fromisoformat(value[:10])
    except ValueError:
        return value
    current = today or date.today()
    delta = (current - captured).days
    if delta < 0:
        return captured.isoformat()
    if delta == 0:
        return "today"
    if delta == 1:
        return "yesterday"
    if delta < 7:
        return f"{delta} days ago"
    if delta < 30:
        weeks = max(1, delta // 7)
        return f"{weeks} week{'s' if weeks != 1 else ''} ago"
    if delta < 365:
        months = max(1, delta // 30)
        return f"{months} month{'s' if months != 1 else ''} ago"
    years = max(1, delta // 365)
    return f"{years} year{'s' if years != 1 else ''} ago"


def dashboard_signals(store: Path) -> dict[str, str]:
    inbox_blocks = split_entry_blocks((store / "inbox.md").read_text())[1]
    candidate_blocks = split_entry_blocks((store / "candidates.md").read_text())[1]
    archive_count = len(list((store / "archive").glob("*.md")))
    all_blocks = [block for _, block in iter_open_entries(store)]
    high_open = sum(1 for block in all_blocks if entry_field(block, "Confidence") == "high")
    stale = sum(1 for block in all_blocks if entry_is_aging(block))
    duplicate_count = sum(1 for block in all_blocks if entry_fields(block, "Additional evidence"))
    blocked = [
        entry_field(block, "Decision note") or entry_field(block, "Follow-up task")
        for block in all_blocks
        if entry_field(block, "Status") == "blocked"
    ]
    calibration_lines = [
        line.removeprefix("- ")
        for line in (store / "calibration.md").read_text().splitlines()
        if line.startswith("- ")
    ]
    ask_prompts = [
        "Ask agent: choose archive, candidate, defer, or follow-up for each needs-review item.",
        "Ask agent: turn code-related decisions into TDD/review tasks before marking done.",
    ]
    return {
        "Needs Review": str(high_open),
        "Open Items": str(len(all_blocks)),
        "Auto Done": str(archive_count),
        "Raw Inbox": str(len(inbox_blocks)),
        "Candidates": str(len(candidate_blocks)),
        "Aging/Stale": str(stale),
        "Likely Duplicates": str(duplicate_count),
        "Calibration Learned": "; ".join(calibration_lines) or "None",
        "Blocked Decisions": "; ".join(item for item in blocked if item) or "None",
        "Ask Agent Prompts": " ".join(ask_prompts),
    }


def entry_is_aging(block: str, today: date | None = None) -> bool:
    captured = entry_field(block, "Captured")
    if not captured:
        return False
    try:
        captured_date = date.fromisoformat(captured[:10])
    except ValueError:
        return False
    current = today or date.today()
    return (current - captured_date).days >= 30


DASHBOARD_TABS: tuple[tuple[str, str, set[str]], ...] = (
    ("inbox", "Inbox", {"inbox", ""}),
    ("triaged", "Triaged", {"candidate", "promoted"}),
    ("blocked", "Blocked", {"blocked"}),
    ("done", "Done", {"archived"}),
)


def render_dashboard_html(
    entries: list[dict[str, object]],
    signals: dict[str, str],
    calibration: list[str],
) -> str:
    panels: dict[str, list[dict[str, object]]] = {key: [] for key, _, _ in DASHBOARD_TABS}
    for entry in entries:
        status = str(entry.get("status") or "")
        for key, _, statuses in DASHBOARD_TABS:
            if status in statuses or (status == "" and key == "inbox"):
                panels[key].append(entry)
                break

    summary_counts: dict[str, int] = {}
    for entry in entries:
        key = " ".join(str(entry.get("summary") or "").lower().split())
        if key:
            summary_counts[key] = summary_counts.get(key, 0) + 1

    open_count = int(signals.get("Open Items", "0") or 0)
    high_count = int(signals.get("Needs Review", "0") or 0)
    duplicate_count = int(signals.get("Likely Duplicates", "0") or 0)
    aging_count = int(signals.get("Aging/Stale", "0") or 0)

    snapshot_parts = [f"{open_count} open"]
    if high_count:
        snapshot_parts.append(f"{high_count} high confidence")
    if duplicate_count:
        snapshot_parts.append(
            f"{duplicate_count} likely duplicate{'s' if duplicate_count != 1 else ''}"
        )
    if aging_count:
        snapshot_parts.append(f"{aging_count} aging")
    snapshot_text = " · ".join(snapshot_parts) if open_count else "Inbox is clear"

    tab_buttons: list[str] = []
    for key, label, _ in DASHBOARD_TABS:
        selected = "true" if key == "inbox" else "false"
        count = len(panels[key])
        tab_buttons.append(
            f'      <button type="button" role="tab" data-tab="{key}" '
            f'aria-selected="{selected}">{html.escape(label)}'
            f'<span class="count">{count}</span></button>'
        )
    tab_buttons.append(
        '      <button type="button" role="tab" data-tab="calibration" '
        'aria-selected="false">Calibration'
        f'<span class="count">{len(calibration)}</span></button>'
    )
    tabs_html = "\n".join(tab_buttons)

    panel_html_parts: list[str] = []
    for key, label, _ in DASHBOARD_TABS:
        items = panels[key]
        hidden = "" if key == "inbox" else " hidden"
        if items:
            cards = "\n".join(_render_card(entry, summary_counts) for entry in items)
        else:
            cards = _render_empty_state(key)
        panel_html_parts.append(
            f'      <section data-panel="{key}" role="tabpanel" aria-label="{html.escape(label)}"{hidden}>\n'
            f"{cards}\n"
            f"      </section>"
        )
    panel_html_parts.append(_render_calibration_panel(calibration))
    panels_html = "\n".join(panel_html_parts)

    signal_items = "\n".join(
        f'        <li><strong>{html.escape(label)}</strong>: {html.escape(value)}</li>'
        for label, value in signals.items()
    )

    return _build_dashboard_page(
        snapshot=html.escape(snapshot_text),
        tabs=tabs_html,
        signal_items=signal_items,
        panels=panels_html,
    )


def _build_dashboard_page(
    snapshot: str,
    tabs: str,
    signal_items: str,
    panels: str,
) -> str:
    today = date.today()
    dateline = today.strftime("%A · %B %-d, %Y")
    issue_no = f"Issue No. {today.strftime('%Y.%j')}"
    return (
        '<!doctype html>\n'
        '<html lang="en">\n'
        '<head>\n'
        '  <meta charset="utf-8">\n'
        '  <meta name="viewport" content="width=device-width, initial-scale=1">\n'
        '  <title>Learnings — Review Journal</title>\n'
        '  <link rel="preconnect" href="https://fonts.googleapis.com">\n'
        '  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>\n'
        '  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?'
        'family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..600&'
        'family=IBM+Plex+Sans:wght@400;500;600&'
        'family=IBM+Plex+Mono:wght@400;500&display=swap">\n'
        '  <style>'
        + _DASHBOARD_CSS
        + '</style>\n'
        '</head>\n'
        '<body>\n'
        '  <header class="app">\n'
        f'    <p class="kicker"><span class="kicker-date">{html.escape(dateline)}</span><span class="kicker-sep" aria-hidden="true">·</span><span class="kicker-issue">{html.escape(issue_no)}</span></p>\n'
        '    <div class="brand">\n'
        '      <span class="brand-dot" aria-hidden="true"></span>\n'
        '      <h1>Learning Dashboard</h1>\n'
        '    </div>\n'
        f'    <p class="snapshot" aria-live="polite">{snapshot}</p>\n'
        '    <div class="app-controls">\n'
        '      <button type="button" id="export" class="btn btn-ghost">Export JSONL</button>\n'
        '      <button type="button" id="finish" class="btn btn-primary">Finish &amp; Execute</button>\n'
        '    </div>\n'
        '    <hr class="masthead-rule" aria-hidden="true">\n'
        '  </header>\n'
        '\n'
        '  <nav class="tabs" role="tablist" aria-label="Learnings tabs">\n'
        f'{tabs}\n'
        '  </nav>\n'
        '\n'
        '  <main>\n'
        '    <details class="signals" id="signals">\n'
        '      <summary>\n'
        '        <span>Triage signals</span>\n'
        '        <span class="hint">All raw counts</span>\n'
        '      </summary>\n'
        '      <ul class="signal-grid">\n'
        f'{signal_items}\n'
        '      </ul>\n'
        '    </details>\n'
        '\n'
        '    <div class="toolbar">\n'
        '      <label class="search">\n'
        '        <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1ZM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/></svg>\n'
        '        <input id="search" type="search" autocomplete="off" placeholder="Filter by title, impact, or guardrail…" aria-label="Filter learnings">\n'
        '      </label>\n'
        '      <div class="filter-chips" role="group" aria-label="Filter by confidence">\n'
        '        <button type="button" class="chip is-active" data-conf="all" aria-pressed="true">All</button>\n'
        '        <button type="button" class="chip" data-conf="high" aria-pressed="false"><span class="conf-dot conf-high"></span>High</button>\n'
        '        <button type="button" class="chip" data-conf="medium" aria-pressed="false"><span class="conf-dot conf-medium"></span>Medium</button>\n'
        '        <button type="button" class="chip" data-conf="low" aria-pressed="false"><span class="conf-dot conf-low"></span>Low</button>\n'
        '      </div>\n'
        '    </div>\n'
        '\n'
        f'{panels}\n'
        '  </main>\n'
        '\n'
        '  <div class="toast" id="toast" role="status" aria-live="polite" hidden></div>\n'
        '\n'
        '  <script>'
        + _DASHBOARD_SCRIPT
        + '</script>\n'
        '</body>\n'
        '</html>\n'
    )


def _confidence_label(value: str) -> str:
    return {"high": "High", "medium": "Medium", "low": "Low"}.get(value, value or "—")


def _render_card(entry: dict[str, object], summary_counts: dict[str, int]) -> str:
    fingerprint = html.escape(str(entry["fingerprint"]))
    summary_text = str(entry["summary"]) or "Untitled learning"
    summary = html.escape(summary_text)
    summary_key = " ".join(summary_text.lower().split())
    ramification = html.escape(str(entry.get("ramification", "")))
    confidence = str(entry.get("confidence") or "low")
    confidence_class = confidence if confidence in {"high", "medium", "low"} else "low"
    confidence_label = _confidence_label(confidence)
    status = str(entry.get("status") or "inbox")
    captured = html.escape(str(entry.get("captured_relative") or entry.get("captured") or ""))
    is_duplicate = summary_key and summary_counts.get(summary_key, 0) > 1
    is_aging = bool(entry.get("is_aging"))
    is_archived = status == "archived"

    artifacts_raw = str(entry.get("prevention_artifacts", ""))
    artifacts_pills = _render_artifact_pills(artifacts_raw)
    artifacts_value = (
        html.escape(artifacts_raw)
        if artifacts_raw
        else '<span class="muted">(none)</span>'
    )
    evidence_raw = str(entry.get("evidence", ""))
    evidence = (
        html.escape(evidence_raw)
        if evidence_raw
        else '<span class="muted">(none captured)</span>'
    )
    additional_evidence_items = [
        f"<li>{html.escape(item)}</li>" for item in entry.get("additional_evidence", []) or []
    ]
    additional_section = ""
    if additional_evidence_items:
        additional_section = (
            '          <div class="field">\n'
            '            <dt>Additional evidence</dt>\n'
            f'            <dd><ul class="field-list">{"".join(additional_evidence_items)}</ul></dd>\n'
            "          </div>"
        )

    recommended = html.escape(str(entry.get("recommended_fix", "")))
    suggested_section = (
        '          <div class="field">\n'
        '            <dt>Suggested fix</dt>\n'
        f'            <dd>{recommended}</dd>\n'
        "          </div>"
        if recommended
        else ""
    )

    pattern = html.escape(str(entry.get("suspected_pattern", "")))
    pattern_section = (
        f'            <div><dt>Pattern</dt><dd>{pattern}</dd></div>\n'
        if pattern and pattern != "Unknown"
        else ""
    )

    sources = html.escape(str(entry.get("sources", "")))
    triggered = html.escape(str(entry.get("source_events", "")))
    triggered_section = (
        f'            <div><dt>Triggered by</dt><dd>{triggered}</dd></div>\n'
        if triggered and triggered != "None"
        else ""
    )

    technical_refs_value = str(entry.get("technical_refs", "")).strip()
    technical_refs_html = html.escape(technical_refs_value or "None")

    prior_items = render_labeled_values(
        [
            ("Decision note", entry.get("decision_notes", [])),
            ("Follow-up task", entry.get("follow_up_tasks", [])),
            ("Draft plan", entry.get("draft_plans", [])),
            ("Draft patch", entry.get("draft_patches", [])),
        ]
    )
    prior_section = (
        '          <div class="field prior">\n'
        '            <dt>Previous decisions</dt>\n'
        f'            <dd>{prior_items}</dd>\n'
        "          </div>"
        if prior_items
        else ""
    )

    badges: list[str] = []
    if is_duplicate:
        badges.append('<span class="badge badge-dup">Lookalike</span>')
    if is_aging:
        badges.append('<span class="badge badge-age">Aging</span>')
    if is_archived:
        badges.append('<span class="badge badge-done">Done</span>')
    badges_html = "".join(badges)

    if is_archived:
        primary_actions = ""
        more_actions = ""
        notes_block = ""
    else:
        primary_actions = (
            '        <div class="actions">\n'
            f'          <button type="button" class="btn btn-primary" data-action="promote" data-fingerprint="{fingerprint}">Adopt</button>\n'
            f'          <button type="button" class="btn" data-action="candidate" data-fingerprint="{fingerprint}">Triage</button>\n'
            f'          <button type="button" class="btn" data-action="archive" data-fingerprint="{fingerprint}">Archive</button>\n'
            f'          <button type="button" class="btn btn-ghost" data-action="defer" data-fingerprint="{fingerprint}">Snooze</button>\n'
            "        </div>"
        )
        more_actions = (
            '          <div class="more-actions">\n'
            f'            <button type="button" class="chip" data-action="block" data-fingerprint="{fingerprint}">Block</button>\n'
            f'            <button type="button" class="chip" data-action="follow-up" data-fingerprint="{fingerprint}">Add follow-up</button>\n'
            f'            <button type="button" class="chip" data-action="draft-plan" data-fingerprint="{fingerprint}">Draft plan</button>\n'
            f'            <button type="button" class="chip" data-action="draft-patch" data-fingerprint="{fingerprint}">Draft patch</button>\n'
            "          </div>"
        )
        notes_block = (
            '          <label class="note-field">\n'
            '            <span>Notes</span>\n'
            f'            <textarea rows="2" data-note-for="{fingerprint}" placeholder="Optional context for this decision…"></textarea>\n'
            "          </label>"
        )

    path = html.escape(str(entry.get("path", "")))

    return (
        f'        <article class="entry" data-fingerprint="{fingerprint}" '
        f'data-status="{html.escape(status)}" data-confidence="{confidence_class}" '
        f'data-aging="{"1" if is_aging else "0"}" '
        f'data-search="{html.escape((summary_text + " " + str(entry.get("ramification", "")) + " " + str(entry.get("prevention_artifacts", ""))).lower())}">\n'
        '          <div class="entry-head">\n'
        '            <div class="entry-title">\n'
        f'              <span class="conf conf-{confidence_class}" aria-hidden="true" title="{confidence_label} confidence"></span>\n'
        f'              <h2>{summary}</h2>\n'
        f'              {badges_html}\n'
        "            </div>\n"
        "          </div>\n"
        f'          <p class="ramification">{ramification}</p>\n'
        '          <div class="entry-meta">\n'
        f"{artifacts_pills}\n"
        f'            <span class="dot-sep" aria-hidden="true">·</span>\n'
        f'            <span class="meta-item meta-conf-{confidence_class}">{confidence_label}</span>\n'
        f'            <span class="dot-sep" aria-hidden="true">·</span>\n'
        f'            <span class="meta-item">{captured or "—"}</span>\n'
        "          </div>\n"
        '          <details class="entry-body">\n'
        '            <summary><span class="open-text">Show context</span><span class="close-text">Hide context</span></summary>\n'
        '            <div class="body">\n'
        '              <dl>\n'
        '          <div class="field">\n'
        '            <dt>Evidence</dt>\n'
        f'            <dd>{evidence}</dd>\n'
        "          </div>\n"
        f"{additional_section}\n"
        f"{suggested_section}\n"
        '          <div class="field">\n'
        '            <dt>Guardrails</dt>\n'
        f'            <dd class="guardrails-value">{artifacts_value}</dd>\n'
        "          </div>\n"
        f"{prior_section}\n"
        '          <details class="tech-details">\n'
        '            <summary>Files &amp; references</summary>\n'
        '            <dl class="tech-grid">\n'
        f'            <div><dt>Technical refs</dt><dd>{technical_refs_html}</dd></div>\n'
        f"{pattern_section}"
        f"{triggered_section}"
        f'            <div><dt>Sources</dt><dd>{sources or "—"}</dd></div>\n'
        f'            <div><dt>Source file</dt><dd><code>{path or "—"}</code></dd></div>\n'
        f'            <div><dt>Fingerprint</dt><dd><code>{fingerprint}</code></dd></div>\n'
        "            </dl>\n"
        "          </details>\n"
        "              </dl>\n"
        f"{notes_block}\n"
        f"{more_actions}\n"
        "            </div>\n"
        "          </details>\n"
        f"{primary_actions}\n"
        "        </article>"
    )


def _render_artifact_pills(value: str) -> str:
    parts = [part.strip() for part in value.split(",") if part.strip()]
    pills: list[str] = []
    for part in parts:
        match = re.match(r"^(.+?)\s*\((required|proposed)\)$", part)
        if match:
            name = match.group(1).strip()
            kind = match.group(2)
        else:
            name = part
            kind = "required"
        is_archive = name.lower() == "archive"
        classes = ["pill", f"pill-{kind}"]
        if is_archive:
            classes.append("pill-archive")
        title = (
            f"{name} ({kind})"
            if not is_archive
            else "marked for archive"
        )
        pills.append(
            f'            <span class="{" ".join(classes)}" title="{html.escape(title)}">'
            f'{html.escape(name)}'
            f'<span class="pill-kind">{kind}</span>'
            "</span>"
        )
    return "\n".join(pills) or '            <span class="muted">No guardrails recorded</span>'


def _render_empty_state(tab: str) -> str:
    messages = {
        "inbox": "Inbox is clear. New captures will land here.",
        "triaged": "Nothing triaged yet. Adopt or hold an inbox item to send it here.",
        "blocked": "No blocked items. Anything waiting on TDD or upstream work will surface here.",
        "done": "No archived learnings yet. Items you archive will rest here.",
    }
    return f'        <div class="empty">{html.escape(messages.get(tab, "Nothing here yet."))}</div>'


def _render_calibration_panel(calibration: list[str]) -> str:
    if calibration:
        rules_html = "".join(
            f'          <li>{html.escape(item)}</li>\n' for item in calibration
        )
        rules_block = (
            '        <ul class="rules">\n'
            f"{rules_html}"
            "        </ul>"
        )
    else:
        rules_block = (
            '        <p class="muted">No house rules captured yet. Add one to teach the agent your taste — '
            'wording you prefer, abstraction levels, prevention choices.</p>'
        )
    return (
        '      <section data-panel="calibration" role="tabpanel" aria-label="Calibration" hidden>\n'
        '        <div class="cal-pane">\n'
        '          <div class="cal-head">\n'
        '            <h2>House rules</h2>\n'
        '            <p>Calibration shapes how the agent triages future captures. Each line is a rule it should respect.</p>\n'
        '          </div>\n'
        f"{rules_block}\n"
        '          <label class="note-field cal-note">\n'
        '            <span>Add a rule</span>\n'
        '            <textarea id="calibration-note" rows="3" placeholder="e.g. Prefer docs candidates before code changes."></textarea>\n'
        '          </label>\n'
        '          <div class="actions">\n'
        '            <button type="button" class="btn btn-primary" id="record-calibration" data-action="calibration">Record rule</button>\n'
        '          </div>\n'
        '        </div>\n'
        "      </section>"
    )


def render_labeled_values(groups: list[tuple[str, object]]) -> str:
    items: list[str] = []
    for label, values in groups:
        if isinstance(values, str):
            value_list = [values] if values else []
        else:
            value_list = [str(value) for value in values if str(value)]
        for value in value_list:
            items.append(
                f"<li><strong>{html.escape(label)}</strong>: {html.escape(value)}</li>"
            )
    if not items:
        return ""
    return '<ul class="prior-list">' + "".join(items) + "</ul>"


