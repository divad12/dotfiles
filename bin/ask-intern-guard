#!/usr/bin/env python3
"""
Claude Code PreToolUse hook that routes broad file reading to ask-intern.

Blocks whole-file reads when they cross either threshold:
- any non-exempt file over ASK_INTERN_GUARD_MAX_LINES lines (default 400)
- cumulative broad reads over ASK_INTERN_GUARD_MAX_CUMULATIVE_LINES lines
  across ASK_INTERN_GUARD_MIN_DISTINCT distinct non-exempt context files

Narrow Read chunks with offset/limit are allowed for exact inspection.
Running ask-intern from Bash resets the session counter.
Durable control docs can opt into direct reads with:
<!-- agent-control: direct-read -->
"""

import hashlib
import json
import os
import re
import shlex
import sys
import time
from pathlib import Path


DEFAULT_MIN_DISTINCT = 3
DEFAULT_MAX_LINES = 400
DEFAULT_MAX_CUMULATIVE_LINES = 800
DEFAULT_MIN_CUMULATIVE_FILE_LINES = 200
DEFAULT_PROBE_MAX_LINES = 40
DEFAULT_ALLOW_TTL_SECONDS = 3600
CONTROL_MARKER = "agent-control: direct-read"
CONTROL_MARKER_SCAN_LINES = 40
READ_COMMANDS = {"cat", "head", "tail", "nl"}
INSTRUCTION_BASENAMES = {"AGENTS.md", "CLAUDE.md", "PROGRESS.md", "SKILL.md"}
REDIRECT_TARGET_TOKENS = {">", ">>", "1>", "1>>", "2>", "2>>", "&>", "<<", "<<<"}
BINARY_EXTENSIONS = {
    ".avif",
    ".bin",
    ".gif",
    ".ico",
    ".jpeg",
    ".jpg",
    ".mov",
    ".mp4",
    ".pdf",
    ".png",
    ".tar",
    ".webp",
    ".zip",
}
DIRECT_READ_RE = re.compile(
    r"(^|[;&|]\s*|\b)(cat|head|tail)\s+|"
    r"\bsed\s+-n\b|"
    r"\bnl\s+-ba\b|"
    r"\bpython3?\b.*\b(read_text|open\()",
)
SHELL_SEGMENT_RE = re.compile(r"\s*(?:&&|\|\||[;]|\n)\s*")


def config_int(name, default):
    try:
        return int(os.environ.get(name, str(default)))
    except ValueError:
        return default


def config_bool(name, default=False):
    value = os.environ.get(name)
    if value is None:
        return default
    return value.lower() in {"1", "true", "yes", "on"}


def state_dir():
    root = os.environ.get("ASK_INTERN_GUARD_DIR", "~/.config/ask-intern/read-guard")
    path = Path(root).expanduser()
    path.mkdir(parents=True, exist_ok=True)
    return path


def session_hash(session_id):
    return hashlib.sha256(session_id.encode("utf-8")).hexdigest()[:16]


def state_path(session_id):
    return state_dir() / f"session-{session_hash(session_id)}.json"


def events_path():
    return state_dir() / "events.jsonl"


def allowances_path():
    return state_dir() / "allow-next.json"


def load_state(session_id):
    path = state_path(session_id)
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return {"paths": [], "reads": []}


def save_state(session_id, state):
    path = state_path(session_id)
    tmp = path.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(tmp, path)


def load_allowances():
    try:
        data = json.loads(allowances_path().read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return []
    if not isinstance(data, list):
        return []
    return [entry for entry in data if isinstance(entry, dict)]


def save_allowances(entries):
    path = allowances_path()
    tmp = path.with_suffix(".tmp")
    tmp.write_text(json.dumps(entries, sort_keys=True) + "\n", encoding="utf-8")
    os.replace(tmp, path)


def tool_input_summary(record):
    tool_input = record.get("tool_input") or {}
    if not isinstance(tool_input, dict):
        return {}

    summary = {}
    for key in ("command", "file_path", "offset", "limit"):
        if key in tool_input:
            summary[key] = tool_input[key]
    return summary


def infer_source_from_text(*values):
    text = " ".join(str(value or "") for value in values).lower()
    if ".codex" in text or "/codex/" in text or "codex.app" in text:
        return "codex"
    if ".claude" in text or "/claude/" in text or "claude" in text:
        return "claude"
    return "unknown"


def detect_source(record, cwd="", command=""):
    explicit = os.environ.get("ASK_INTERN_SOURCE", "").strip().lower()
    if explicit:
        return explicit
    env_hint = " ".join(
        f"{key}={value}"
        for key, value in os.environ.items()
        if "CODEX" in key or "CLAUDE" in key or "ANTHROPIC" in key
    )
    source = infer_source_from_text(env_hint, cwd, command, json.dumps(record or {}, sort_keys=True))
    if source != "unknown":
        return source
    if "CODEX_" in env_hint:
        return "codex"
    if "ANTHROPIC" in env_hint:
        return "claude"
    return "unknown"


def log_event(
    session_id,
    action,
    reason="",
    paths=None,
    cwd="",
    tool_name="",
    command="",
    record=None,
    read_lines=None,
    total_lines=None,
    distinct_files=None,
):
    event = {
        "ts": int(time.time()),
        "session": session_hash(session_id) if session_id else "",
        "source": detect_source(record, cwd, command),
        "action": action,
        "reason": reason,
        "paths": paths or [],
        "cwd": cwd,
        "tool": tool_name,
        "command": command,
    }
    if record is not None:
        event["hook_event_name"] = record.get("hook_event_name", "")
        event["tool_input"] = tool_input_summary(record)
    if read_lines is not None:
        event["read_lines"] = read_lines
    if total_lines is not None:
        event["total_lines"] = total_lines
    if distinct_files is not None:
        event["distinct_files"] = distinct_files
    try:
        with events_path().open("a", encoding="utf-8") as f:
            f.write(json.dumps(event, sort_keys=True) + "\n")
    except OSError:
        pass


def read_input():
    try:
        return json.load(sys.stdin)
    except json.JSONDecodeError:
        return {}


def normalize_path(path, cwd):
    if not path:
        return ""
    expanded = os.path.expanduser(path)
    if not os.path.isabs(expanded):
        expanded = os.path.join(cwd or os.getcwd(), expanded)
    return os.path.realpath(expanded)


def has_direct_read_marker(path):
    try:
        with open(path, "r", encoding="utf-8", errors="ignore") as f:
            for index, line in enumerate(f):
                if index >= CONTROL_MARKER_SCAN_LINES:
                    break
                if CONTROL_MARKER in line.lower():
                    return True
    except OSError:
        return False
    return False


def is_docs_path(path):
    return "docs" in Path(path).parts


def is_durable_control_doc(path):
    return is_docs_path(path)


def is_binary_path(path):
    return Path(path).suffix.lower() in BINARY_EXTENSIONS


def is_exempt_path(path):
    parts = Path(path).parts
    basename = os.path.basename(path)
    if basename in INSTRUCTION_BASENAMES:
        return True
    if is_binary_path(path):
        return True
    joined = "/".join(parts)
    if "/docs/ai/" in joined:
        return True
    if "/.agents/observations/" in joined:
        return True
    if is_durable_control_doc(path):
        return True
    if has_direct_read_marker(path):
        return True
    return False


def add_allowance(path, reason):
    now = int(time.time())
    ttl = config_int("ASK_INTERN_GUARD_ALLOW_TTL", DEFAULT_ALLOW_TTL_SECONDS)
    entries = [
        entry for entry in load_allowances()
        if int(entry.get("expires_at", 0) or 0) > now and entry.get("path") != path
    ]
    entries.append({
        "created_at": now,
        "expires_at": now + ttl,
        "path": path,
        "reason": reason,
    })
    save_allowances(entries)


def consume_allowance(path):
    now = int(time.time())
    entries = load_allowances()
    kept = []
    consumed = False
    for entry in entries:
        expires_at = int(entry.get("expires_at", 0) or 0)
        if expires_at <= now:
            continue
        if not consumed and entry.get("path") == path:
            consumed = True
            continue
        kept.append(entry)
    if consumed or len(kept) != len(entries):
        save_allowances(kept)
    return consumed


def line_count(path):
    try:
        with open(path, "r", encoding="utf-8", errors="ignore") as f:
            return sum(1 for _ in f)
    except OSError:
        return None


def read_candidate(path, lines=None):
    if lines is None:
        lines = line_count(path)
    return {"path": path, "lines": lines}


def candidate_path(candidate):
    return candidate.get("path", "")


def candidate_lines(candidate):
    lines = candidate.get("lines")
    if lines is not None:
        return lines
    return line_count(candidate_path(candidate))


def estimate_range_lines(path, offset, limit):
    total = line_count(path)
    if total is None:
        return limit
    start = 1
    if offset is not None:
        try:
            start = max(1, int(offset))
        except (TypeError, ValueError):
            start = 1
    remaining = max(0, total - start + 1)
    if limit is None:
        return remaining
    try:
        return min(max(0, int(limit)), remaining)
    except (TypeError, ValueError):
        return remaining


def basename_list(paths):
    return ", ".join(os.path.basename(path) for path in paths)


def ask_intern_command(paths):
    flags = " ".join(f"-f {shlex.quote(path)}" for path in paths[:8])
    if len(paths) > 8:
        flags += " ..."
    return f'ask-intern {flags} "summarize the parts I need for this task"'


def deny(reason):
    print(reason, file=sys.stderr)
    sys.exit(2)


def warn_or_deny(reason):
    if os.environ.get("ASK_INTERN_GUARD_MODE", "deny") == "warn":
        print(json.dumps({
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": "allow",
                "permissionDecisionReason": reason,
            }
        }))
        return
    deny(reason)


def is_ask_intern_command(command):
    try:
        tokens = shlex.split(command)
    except ValueError:
        tokens = command.split()
    return any(os.path.basename(token) == "ask-intern" for token in tokens)


def existing_file(path):
    try:
        return Path(path).is_file()
    except OSError:
        return False


def split_shell_segments(command):
    return [segment.strip() for segment in SHELL_SEGMENT_RE.split(command) if segment.strip()]


def parse_positive_int(value):
    try:
        parsed = int(str(value).strip())
    except (TypeError, ValueError):
        return None
    return parsed if parsed >= 0 else None


def parse_head_tail_limit(tokens, command_index):
    limit = 10
    index = command_index + 1
    while index < len(tokens):
        token = tokens[index]
        if token in REDIRECT_TARGET_TOKENS:
            index += 2
            continue
        if token in {"-n", "--lines"} and index + 1 < len(tokens):
            parsed = parse_positive_int(tokens[index + 1])
            if parsed is not None:
                limit = parsed
            index += 2
            continue
        if token.startswith("--lines="):
            parsed = parse_positive_int(token.split("=", 1)[1])
            if parsed is not None:
                limit = parsed
            index += 1
            continue
        if re.match(r"^-\d+$", token):
            parsed = parse_positive_int(token[1:])
            if parsed is not None:
                limit = parsed
            index += 1
            continue
        if token.startswith("-"):
            index += 1
            continue
        break
    return limit


def parse_sed_limit(script):
    script = script.strip()
    match = re.match(r"^(\d+),(\d+)p$", script)
    if match:
        start = int(match.group(1))
        end = int(match.group(2))
        return max(0, end - start + 1)
    if re.match(r"^\d+p$", script):
        return 1
    return None


def next_pipe_index(tokens, start):
    try:
        return tokens.index("|", start)
    except ValueError:
        return len(tokens)


def parse_downstream_sed_limit(tokens, command_index):
    if "-n" not in tokens[command_index + 1 : command_index + 4]:
        return None
    end = next_pipe_index(tokens, command_index + 1)
    for token in tokens[command_index + 1 : end]:
        if token == "-n" or token.startswith("-"):
            continue
        return parse_sed_limit(token)
    return None


def parse_downstream_wc_limit(tokens, command_index):
    end = next_pipe_index(tokens, command_index + 1)
    args = tokens[command_index + 1 : end]
    if any(token == "-l" or token == "--lines" or (token.startswith("-") and "l" in token) for token in args):
        return 1
    return None


def downstream_pipeline_line_limit(tokens, command_index):
    limits = []
    search_index = command_index + 1
    while True:
        try:
            pipe_index = tokens.index("|", search_index)
        except ValueError:
            break
        if pipe_index + 1 >= len(tokens):
            break
        downstream = os.path.basename(tokens[pipe_index + 1])
        if downstream in {"head", "tail"}:
            limits.append(parse_head_tail_limit(tokens, pipe_index + 1))
        elif downstream == "sed":
            limit = parse_downstream_sed_limit(tokens, pipe_index + 1)
            if limit is not None:
                limits.append(limit)
        elif downstream == "wc":
            limit = parse_downstream_wc_limit(tokens, pipe_index + 1)
            if limit is not None:
                limits.append(limit)
        search_index = pipe_index + 1
    return min(limits) if limits else None


def extract_segment_read_candidates(segment, cwd):
    try:
        tokens = shlex.split(segment)
    except ValueError:
        tokens = segment.split()
    if not tokens:
        return []

    candidates = []
    read_index = None
    sed_index = None
    for index, token in enumerate(tokens):
        base = os.path.basename(token)
        if base in READ_COMMANDS:
            read_index = index
            break
        if base == "sed" and "-n" in tokens[index + 1:index + 4]:
            sed_index = index
            break

    if read_index is None and sed_index is None:
        return []

    start = read_index if read_index is not None else sed_index
    command = os.path.basename(tokens[start])
    line_limit = None
    pipeline_limit = downstream_pipeline_line_limit(tokens, start)
    if command in {"head", "tail"}:
        line_limit = parse_head_tail_limit(tokens, start)
        if pipeline_limit is not None:
            line_limit = min(line_limit, pipeline_limit)
        if line_limit <= config_int("ASK_INTERN_GUARD_PROBE_MAX_LINES", DEFAULT_PROBE_MAX_LINES):
            return []
    elif pipeline_limit is not None:
        line_limit = pipeline_limit
        if line_limit <= config_int("ASK_INTERN_GUARD_PROBE_MAX_LINES", DEFAULT_PROBE_MAX_LINES):
            return []

    sed_script = None
    if sed_index is not None:
        for token in tokens[start + 1:]:
            if token == "-n" or token.startswith("-"):
                continue
            sed_script = token
            line_limit = parse_sed_limit(token)
            break

    skip_next = False
    for index, token in enumerate(tokens[start + 1:], start + 1):
        if skip_next:
            skip_next = False
            continue
        if token in REDIRECT_TARGET_TOKENS:
            skip_next = True
            continue
        if re.match(r"^(?:\d?>?>|&>|<<).+", token):
            continue
        if token.startswith("-"):
            continue
        if token in {"|", "&&", "||", ";"}:
            break
        if sed_index is not None and (index <= sed_index + 1 or token == sed_script):
            continue
        if re.match(r"^\d*>\S*", token):
            continue
        normalized = normalize_path(token, cwd)
        if existing_file(normalized):
            if command in {"head", "tail"} and line_limit is not None:
                total = line_count(normalized)
                lines = line_limit if total is None else min(line_limit, total)
            elif sed_index is not None and line_limit is not None:
                total = line_count(normalized)
                lines = line_limit if total is None else min(line_limit, total)
            else:
                lines = line_count(normalized)
            candidates.append(read_candidate(normalized, lines))

    return candidates


def extract_bash_read_candidates(command, cwd):
    if not DIRECT_READ_RE.search(command):
        return []

    candidates = []
    for segment in split_shell_segments(command):
        if DIRECT_READ_RE.search(segment):
            candidates.extend(extract_segment_read_candidates(segment, cwd))

    by_path = {}
    for candidate in candidates:
        path = candidate_path(candidate)
        lines = candidate_lines(candidate)
        if path not in by_path or (lines or 0) > (by_path[path].get("lines") or 0):
            by_path[path] = read_candidate(path, lines)
    return [by_path[path] for path in sorted(by_path)]


def reset_after_delegation(record, session_id, state):
    tool_name = record.get("tool_name", "")
    tool_input = record.get("tool_input") or {}
    command = tool_input.get("command", "") if isinstance(tool_input, dict) else ""
    if tool_name == "Bash" and isinstance(command, str) and is_ask_intern_command(command):
        state["paths"] = []
        state["reads"] = []
        state["delegated_at"] = int(time.time())
        save_state(session_id, state)
        log_event(
            session_id,
            "delegated",
            paths=[],
            cwd=record.get("cwd", ""),
            tool_name=tool_name,
            command=command,
            record=record,
        )
        return True
    return False


def consume_allowed_candidates(candidates, session_id, record):
    remaining = []
    for candidate in candidates:
        path = candidate_path(candidate)
        if is_exempt_path(path):
            remaining.append(candidate)
            continue
        if consume_allowance(path):
            log_event(
                session_id,
                "allowed",
                reason="allow_next",
                paths=[path],
                cwd=record.get("cwd", ""),
                tool_name=record.get("tool_name", ""),
                command=(record.get("tool_input") or {}).get("command", ""),
                record=record,
                read_lines=candidate_lines(candidate),
            )
            continue
        remaining.append(candidate)
    return remaining


def candidate_reads(record):
    tool_name = record.get("tool_name", "")
    tool_input = record.get("tool_input") or {}
    cwd = record.get("cwd") or os.getcwd()
    if not isinstance(tool_input, dict):
        return []

    if tool_name == "Read":
        path = normalize_path(tool_input.get("file_path", ""), cwd)
        if not path:
            return []
        if "offset" in tool_input or "limit" in tool_input:
            lines = estimate_range_lines(path, tool_input.get("offset"), tool_input.get("limit"))
            return [read_candidate(path, lines)]
        return [read_candidate(path)]

    if tool_name == "Bash":
        command = tool_input.get("command", "")
        if not isinstance(command, str):
            return []
        return extract_bash_read_candidates(command, cwd)

    return []


def check_large_file(candidates, session_id, record):
    max_lines = config_int("ASK_INTERN_GUARD_MAX_LINES", DEFAULT_MAX_LINES)
    for candidate in candidates:
        path = candidate_path(candidate)
        if is_exempt_path(path):
            continue
        lines = candidate_lines(candidate)
        if lines is None or lines <= max_lines:
            continue
        reason = (
            f"ask-intern guard: this would read {lines} lines from {path} (>{max_lines}). "
            f"Use `ask-intern -f {shlex.quote(path)} \"summarize what I need\"` before reading it, "
            "then read only narrow snippets needed for exact line numbers, verification, or edits."
        )
        log_event(
            session_id,
            "blocked",
            reason="large_file",
            paths=[path],
            cwd=record.get("cwd", ""),
            tool_name=record.get("tool_name", ""),
            command=(record.get("tool_input") or {}).get("command", ""),
            record=record,
            read_lines=lines,
        )
        warn_or_deny(reason)


def state_read_entries(state):
    entries = []
    raw_reads = state.get("reads")
    if isinstance(raw_reads, list):
        for entry in raw_reads:
            if not isinstance(entry, dict):
                continue
            path = entry.get("path", "")
            if not path:
                continue
            entries.append(read_candidate(path, entry.get("lines")))
    if entries:
        return entries

    for path in state.get("paths") or []:
        if path:
            entries.append(read_candidate(path))
    return entries


def merge_read_entries(existing_entries, new_candidates):
    merged = {}
    order = []
    for candidate in existing_entries + new_candidates:
        path = candidate_path(candidate)
        if not path:
            continue
        lines = candidate_lines(candidate)
        if path not in merged:
            order.append(path)
            merged[path] = read_candidate(path, lines)
            continue
        if (lines or 0) > (merged[path].get("lines") or 0):
            merged[path] = read_candidate(path, lines)
    return [merged[path] for path in order]


def cumulative_candidates(candidates):
    min_lines = config_int("ASK_INTERN_GUARD_MIN_CUMULATIVE_FILE_LINES", DEFAULT_MIN_CUMULATIVE_FILE_LINES)
    relevant = []
    for candidate in candidates:
        if is_exempt_path(candidate_path(candidate)):
            continue
        lines = candidate_lines(candidate)
        if lines is None or lines >= min_lines:
            relevant.append(candidate)
    return relevant


def check_cumulative_reads(candidates, session_id, state, record):
    min_distinct = config_int("ASK_INTERN_GUARD_MIN_DISTINCT", DEFAULT_MIN_DISTINCT)
    max_cumulative = config_int("ASK_INTERN_GUARD_MAX_CUMULATIVE_LINES", DEFAULT_MAX_CUMULATIVE_LINES)
    relevant = cumulative_candidates(candidates)
    if not relevant:
        return

    combined = merge_read_entries(cumulative_candidates(state_read_entries(state)), relevant)
    combined_paths = [candidate_path(candidate) for candidate in combined]
    total_lines = sum(candidate_lines(candidate) or 0 for candidate in combined)

    if len(combined) >= min_distinct and total_lines >= max_cumulative:
        reason = (
            f"ask-intern guard: this would broadly read about {total_lines} lines across "
            f"{len(combined)} distinct context files ({basename_list(combined_paths[:min_distinct])}). "
            f"Use `{ask_intern_command(combined_paths)}` first. "
            "After the intern summary, read only narrow snippets needed for exact line numbers, verification, or edits."
        )
        log_event(
            session_id,
            "blocked",
            reason="cumulative_lines",
            paths=[candidate_path(candidate) for candidate in relevant],
            cwd=record.get("cwd", ""),
            tool_name=record.get("tool_name", ""),
            command=(record.get("tool_input") or {}).get("command", ""),
            record=record,
            read_lines=sum(candidate_lines(candidate) or 0 for candidate in relevant),
            total_lines=total_lines,
            distinct_files=len(combined),
        )
        warn_or_deny(reason)
        return

    state["reads"] = combined
    state["paths"] = combined_paths
    save_state(session_id, state)
    log_event(
        session_id,
        "tracked",
        paths=[candidate_path(candidate) for candidate in relevant],
        cwd=record.get("cwd", ""),
        tool_name=record.get("tool_name", ""),
        command=(record.get("tool_input") or {}).get("command", ""),
        record=record,
        read_lines=sum(candidate_lines(candidate) or 0 for candidate in relevant),
        total_lines=total_lines,
        distinct_files=len(combined),
    )


def main():
    if len(sys.argv) > 1:
        if sys.argv[1] in {"-h", "--help"}:
            print("Usage: ask-intern-guard [--allow-next PATH [reason...]]")
            return
        if sys.argv[1] == "--allow-next":
            if len(sys.argv) < 3:
                print("ask-intern guard: --allow-next requires a path", file=sys.stderr)
                sys.exit(1)
            path = normalize_path(sys.argv[2], os.getcwd())
            if not existing_file(path):
                print(f"ask-intern guard: cannot allow missing file: {path}", file=sys.stderr)
                sys.exit(1)
            reason = " ".join(sys.argv[3:]) or "manual direct-read override"
            add_allowance(path, reason)
            print(f"ask-intern guard: next direct read allowed for {path}")
            return
        print(f"ask-intern guard: unknown argument: {sys.argv[1]}", file=sys.stderr)
        sys.exit(1)

    if config_bool("ASK_INTERN_GUARD_DISABLED"):
        return

    record = read_input()
    session_id = record.get("session_id", "")
    if not session_id:
        return

    state = load_state(session_id)
    if reset_after_delegation(record, session_id, state):
        return

    candidates = candidate_reads(record)
    if not candidates:
        return

    candidates = consume_allowed_candidates(candidates, session_id, record)
    check_large_file(candidates, session_id, record)
    check_cumulative_reads(candidates, session_id, state, record)


if __name__ == "__main__":
    main()
